<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard | CampusHire</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body { font-family: 'Sora', sans-serif; background: #f1f5f9; color: #0f172a; }

/* NAVBAR */
.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40px;
  height: 60px;
  background: #fff;
  border-bottom: 1px solid #e2e8f0;
  position: sticky;
  top: 0;
  z-index: 100;
}
.logo { font-weight: 700; font-size: 18px; color: #2563eb; letter-spacing: -0.5px; }
.nav-links a {
  margin: 0 12px;
  text-decoration: none;
  color: #64748b;
  font-size: 14px;
  font-weight: 600;
  transition: color 0.2s;
}
.nav-links a:hover { color: #2563eb; }

.nav-right { display: flex; align-items: center; gap: 12px; }
.avatar {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-weight: 700; font-size: 14px;
}

/* HERO */
.hero {
  background: linear-gradient(135deg, #1e2a5a, #2563eb, #4f46e5);
  color: white;
  padding: 36px 40px;
  margin: 24px;
  border-radius: 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.hero-left h2 { font-size: 28px; margin-bottom: 6px; }
.hero-left p { color: #c7d2fe; font-size: 14px; }
.hero-right {
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 14px 22px;
  border-radius: 14px;
  text-align: center;
}
.hero-right .streak-num { font-size: 32px; font-weight: 700; }
.hero-right .streak-lbl { font-size: 12px; color: #c7d2fe; margin-top: 2px; }

/* STATS */
.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin: 0 24px 24px;
}
.stat-card {
  background: #fff;
  padding: 22px 20px;
  border-radius: 14px;
  border: 1px solid #e2e8f0;
  position: relative;
  overflow: hidden;
}
.stat-card .icon {
  font-size: 22px;
  margin-bottom: 10px;
}
.stat-card h3 { font-size: 26px; color: #0f172a; font-weight: 700; }
.stat-card p { font-size: 13px; color: #64748b; margin-top: 4px; }
.stat-card .badge-pill {
  position: absolute;
  top: 16px; right: 16px;
  padding: 3px 10px;
  border-radius: 50px;
  font-size: 11px;
  font-weight: 700;
}
.ready { background: #dcfce7; color: #16a34a; }
.not-ready { background: #fee2e2; color: #dc2626; }

/* GRID */
.grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 20px;
  margin: 0 24px 24px;
}

/* CARD */
.card {
  background: #fff;
  padding: 22px;
  border-radius: 14px;
  border: 1px solid #e2e8f0;
  margin-bottom: 18px;
}
.card:last-child { margin-bottom: 0; }
.card h3 { font-size: 15px; color: #0f172a; margin-bottom: 16px; font-weight: 700; }

/* PROGRESS */
.progress-track {
  background: #f1f5f9;
  height: 8px;
  border-radius: 8px;
  overflow: hidden;
  margin-top: 4px;
}
.progress-fill {
  height: 100%;
  border-radius: 8px;
  width: var(--w);
  background: var(--c);
  transition: width 0.6s ease;
}

.topic-row { margin-bottom: 14px; }
.topic-meta {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #475569;
  margin-bottom: 6px;
}

/* LIST */
.list-item {
  padding: 12px 14px;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  margin-bottom: 10px;
  font-size: 14px;
}
.list-item b { color: #0f172a; }
.list-item small { color: #94a3b8; font-size: 12px; }

/* COMPANY TAG */
.company-tag {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 14px;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  margin-bottom: 10px;
  font-size: 14px;
}
.readiness-badge {
  padding: 3px 10px;
  border-radius: 50px;
  font-size: 12px;
  font-weight: 700;
  background: #dbeafe;
  color: #1d4ed8;
}

/* TIP */
.tip-card {
  background: linear-gradient(135deg, #eff6ff, #f0fdf4);
  border: 1px solid #bfdbfe;
  padding: 18px;
  border-radius: 12px;
  font-size: 14px;
  line-height: 1.6;
  color: #1e40af;
}
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">CampusHire</div>
  <div class="nav-links">
    <a href="/dashboard">Dashboard</a>
    <a href="/prepare">Companies</a>
    <a href="/question-bank">Question Bank</a>
    <a href="/analytics">Analytics</a>
  </div>
  <div class="nav-right">
    <!-- First letter of name as avatar -->
    <div class="avatar"><%= student.name.charAt(0).toUpperCase() %></div>
    <span style="font-size:14px; font-weight:600; color:#334155;"><%= student.name %></span>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-left">
    <h2>Hi, <%= student.name.split(' ')[0] %> 👋</h2>
    <p><%= student.branch %> · Batch of <%= student.batch %></p>
  </div>
  <div class="hero-right">
    <div class="streak-num">🔥 <%= student.streak %></div>
    <div class="streak-lbl">Day Streak</div>
  </div>
</div>

<!-- STATS -->
<div class="stats">

  <div class="stat-card">
    <div class="icon">💻</div>
    <h3><%= student.dsaSolved %></h3>
    <p>DSA Problems Solved</p>
  </div>

  <div class="stat-card">
    <div class="icon">📝</div>
    <h3><%= student.mockScore %>%</h3>
    <p>Avg. Mock Score</p>
  </div>

  <div class="stat-card">
    <div class="icon">🏢</div>
    <h3><%= student.targetCompanies.length %></h3>
    <p>Target Companies</p>
  </div>

  <div class="stat-card">
    <div class="icon">🎯</div>
    <h3><%= student.overallProgress %>%</h3>
    <p>Overall Progress</p>
    <span class="badge-pill <%= student.overallProgress >= 70 ? 'ready' : 'not-ready' %>">
      <%= student.overallProgress >= 70 ? '✅ Ready' : '⏳ In Progress' %>
    </span>
  </div>

</div>

<!-- MAIN GRID -->
<div class="grid">

  <!-- LEFT COLUMN -->
  <div>

    <!-- OVERALL PROGRESS -->
    <div class="card">
      <h3>Overall Placement Readiness</h3>
      <div class="topic-meta">
        <span>Progress</span>
        <span><%= student.overallProgress %>%</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" style="--w: <%= student.overallProgress %>%; --c: #2563eb;"></div>
      </div>
    </div>

    <!-- TOPIC BREAKDOWN -->
    <div class="card">
      <h3>Preparation Breakdown</h3>
      <% student.topics.forEach(t => { %>
        <div class="topic-row">
          <div class="topic-meta">
            <span><%= t.name %></span>
            <span><%= t.solved %>/<%= t.total %></span>
          </div>
          <div class="progress-track">
            <div class="progress-fill" style="--w: <%= Number((t.solved / t.total) * 100 || 0).toFixed(0) %>%; --c: <%= t.color %>;"></div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- UPCOMING -->
    <div class="card">
      <h3>📅 Upcoming Campus Drives</h3>
      <% student.upcomingCompanies.forEach(c => { %>
        <div class="list-item">
          <b><%= c.name %></b>
          <span style="float:right; color:#64748b; font-size:13px;"><%= c.date %></span>
        </div>
      <% }) %>
    </div>

  </div>

  <!-- RIGHT COLUMN -->
  <div>

    <!-- TARGET COMPANIES -->
    <div class="card">
      <h3>🎯 Target Companies</h3>
      <% student.targetCompanies.forEach(c => { %>
        <div class="company-tag">
          <span><b><%= c.name %></b></span>
          <span class="readiness-badge"><%= c.readiness %>%</span>
        </div>
      <% }) %>
    </div>

    <!-- RECENT ACTIVITY -->
    <div class="card">
      <h3>⚡ Recent Activity</h3>
      <% student.recentActivity.forEach(a => { %>
        <div class="list-item">
          <%= a.title %><br>
          <small><%= a.time %></small>
        </div>
      <% }) %>
    </div>

    <!-- TIP -->
    <div class="tip-card">
      💡 <b>Today's Tip</b><br>
      <%= student.dailyTip %>
    </div>

  </div>

</div>

</body>
</html>