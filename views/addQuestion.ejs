<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Add Experience</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: Inter, Arial, sans-serif;
}

body{
  height:100vh;
  background:linear-gradient(135deg,#1e3a8a,#3b82f6,#93c5fd);
  display:flex;
  justify-content:center;
  align-items:center;
}

/* GLASS CARD */
.container{
  background:rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  padding:30px 35px;
  width:420px;
  border-radius:20px;
  box-shadow:0 15px 40px rgba(0,0,0,0.25);
}

/* HEADER */
.header{
  text-align:center;
  margin-bottom:20px;
}

.header h2{
  color:#1e3a8a;
}

.header p{
  color:#64748b;
  font-size:14px;
}

/* INPUT GROUP */
.group{
  margin-bottom:15px;
}

.group label{
  font-size:13px;
  color:#374151;
  display:block;
  margin-bottom:5px;
}

.group input,
.group select,
.group textarea{
  width:100%;
  padding:10px 12px;
  border-radius:10px;
  border:1px solid #c7d2fe;
  outline:none;
  transition:0.2s;
}

.group textarea{
  resize:none;
  height:80px;
}

.group input:focus,
.group select:focus,
.group textarea:focus{
  border-color:#2563eb;
  box-shadow:0 0 0 2px rgba(37,99,235,0.2);
}

/* BUTTON */
button{
  width:100%;
  padding:12px;
  border:none;
  border-radius:12px;
  background:linear-gradient(135deg,#2563eb,#1d4ed8);
  color:white;
  font-size:15px;
  font-weight:600;
  cursor:pointer;
  transition:0.3s;
}

button:hover{
  transform:translateY(-2px);
  box-shadow:0 8px 20px rgba(37,99,235,0.4);
}

/* BACK LINK */
.back{
  text-align:center;
  margin-top:15px;
}

.back a{
  text-decoration:none;
  color:#2563eb;
  font-size:13px;
}

.back a:hover{
  text-decoration:underline;
}
</style>

</head>

<body>

<div class="container">

  <div class="header">
    <h2>Add Your Experience ✍️</h2>
    <p>Help juniors by sharing real interview questions</p>
  </div>

  <form action="/add-question" method="POST">

    <input type="hidden" name="company" value="<%= company %>">

    <div class="group">
      <label>Question</label>
      <textarea name="questionText" placeholder="Enter interview question..." required></textarea>
    </div>

    <div class="group">
      <label>Category</label>
      <select name="category">
        <option value="dsa">DSA</option>
        <option value="technical">Technical</option>
        <option value="hr">HR</option>
      </select>
    </div>

    <div class="group">
      <label>Difficulty</label>
      <select name="difficulty">
        <option>Easy</option>
        <option>Medium</option>
        <option>Hard</option>
      </select>
    </div>

    <div class="group">
      <label>Approach / Answer</label>
      <textarea name="approach" placeholder="Explain how to solve..."></textarea>
    </div>

    <button type="submit">🚀 Submit Question</button>

  </form>

  <div class="back">
    <a href="/company/<%= company %>">← Back to Company</a>
  </div>

</div>

</body>
</html>