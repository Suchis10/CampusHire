<!-- CHAT PANEL -->
<div class="chat-panel" id="chatPanel">
  <div class="panel-header">
    <div class="panel-avatar">
      <svg viewBox="0 0 24 24"><path d="M12 2a2 2 0 012 2v1h3a2 2 0 012 2v10a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2h3V4a2 2 0 012-2z"/></svg>
    </div>
    <div class="panel-info">
      <p>Hire Bot</p>
      <span><span class="online"></span> AI Resume Analyser · Powered by HireAbilityAPI</span>
    </div>
    <button class="panel-close" onclick="toggleChat()">✕</button>
  </div>

  <div class="panel-messages" id="panelMessages">
    <div class="pmsg bot">
      <div class="pmsg-av bot">H</div>
      <div class="pmsg-text">Hi! 👋 I'm <strong>Hire Bot</strong>. Upload your resume and I'll analyse it for campus placements — checking skills, projects, ATS score, and more!</div>
    </div>
    <div class="pmsg bot">
      <div class="pmsg-av bot">H</div>
      <div>
        <div class="upload-prompt" onclick="document.getElementById('resumeInput').click()">
          <p>📄 Upload your Resume (PDF)</p>
          <small>Click here or drag & drop · Max 5MB</small>
        </div>
      </div>
    </div>
  </div>

  <div class="panel-quick" id="panelQuick">
    <button class="pquick" onclick="pq('Analyse for TCS')">For TCS</button>
    <button class="pquick" onclick="pq('Check ATS score')">ATS check</button>
    <button class="pquick" onclick="pq('Missing skills?')">Missing skills</button>
    <button class="pquick" onclick="pq('Improve projects section')">Projects</button>
  </div>

  <div class="panel-input-row">
    <input class="panel-input" id="panelInput" placeholder="Ask about your resume…" />
    <button class="panel-send" id="panelSend" onclick="panelSend()">
      <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
    </button>
  </div>
</div>

<input type="file" id="resumeInput" accept=".pdf"/>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

  let chatOpen = false;
  let resumeText = '';
  let chatHistory = [];

  function toggleChat() {
    chatOpen = !chatOpen;
    document.getElementById('chatPanel').classList.toggle('open', chatOpen);
    document.getElementById('bubbleIcon').style.display = chatOpen ? 'none' : 'block';
    document.getElementById('closeIcon').style.display = chatOpen ? 'block' : 'none';
  }

  document.getElementById('resumeInput').addEventListener('change', function() {
    if (this.files[0]) handleResume(this.files[0]);
  });

  async function handleResume(file) {
    if (file.size > 5 * 1024 * 1024) { addPanelBot('File too large. Please upload a PDF under 5MB.'); return; }

    addPanelUser('📄 ' + file.name);
    addPanelTyping();

    try {
      const ab = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
      let text = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        text += content.items.map(i => i.str).join(' ') + '\n';
      }
      resumeText = text.trim();
      removePanelTyping();

      if (!resumeText || resumeText.length < 50) {
        addPanelBot('Could not read text from this PDF. Please upload a text-based (not scanned) PDF.'); return;
      }

      const fileOk = document.createElement('div');
      fileOk.className = 'pmsg bot';
      fileOk.innerHTML = `<div class="pmsg-av bot">H</div><div><div class="file-ok">✓ ${file.name} — analysing now…</div></div>`;
      document.getElementById('panelMessages').appendChild(fileOk);
      scrollPanel();

      chatHistory = [];
      await getChatReply('Do a full campus placement analysis of this resume. Cover: ATS score out of 10, key skills found, top 3 missing skills for Indian campus companies, projects quality, and 3 improvement tips. Be concise and clear.');
    } catch(e) {
      removePanelTyping();
      addPanelBot('Error reading PDF. Make sure it is a valid text-based PDF.');
    }
  }

  async function panelSend() {
    const val = document.getElementById('panelInput').value.trim();
    if (!val) return;
    document.getElementById('panelInput').value = '';
    if (!resumeText) { addPanelUser(val); addPanelBot('Please upload your resume first so I can help you!'); return; }
    addPanelUser(val);
    addPanelTyping();
    await getChatReply(val);
  }

  async function pq(msg) {
    if (!resumeText) { toggleChat(); addPanelBot('Please upload your resume first!'); return; }
    addPanelUser(msg);
    addPanelTyping();
    await getChatReply(msg);
  }

  async function getChatReply(userMsg) {
    const system = `You are Hire Bot, an expert campus placement advisor for Indian engineering students. You know what TCS, Infosys, Wipro, Accenture, Amazon, and other campus recruiters look for. The student's resume: ---\n${resumeText}\n--- Give specific, actionable, concise feedback. For scoring use /10. Tailor for Indian campus placements.`;
    chatHistory.push({ role: 'user', content: userMsg });
    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ system, messages: chatHistory })
      });
      const data = await res.json();
      const reply = data.content[0].text;
      chatHistory.push({ role: 'assistant', content: reply });
      removePanelTyping();
      addPanelBot(reply);
    } catch(e) {
      removePanelTyping();
      addPanelBot('Something went wrong. Please make sure the server is running.');
    }
  }

  function addPanelUser(text) {
    const d = document.createElement('div');
    d.className = 'pmsg user';
    d.innerHTML = `<div class="pmsg-av usr">U</div><div class="pmsg-text">${esc(text)}</div>`;
    document.getElementById('panelMessages').appendChild(d);
    scrollPanel();
  }

  function addPanelBot(html) {
    const d = document.createElement('div');
    d.className = 'pmsg bot';
    d.innerHTML = `<div class="pmsg-av bot">H</div><div class="pmsg-text">${fmt(html)}</div>`;
    document.getElementById('panelMessages').appendChild(d);
    scrollPanel();
  }

  function addPanelTyping() {
    const d = document.createElement('div');
    d.className = 'pmsg bot'; d.id = 'ptyping';
    d.innerHTML = `<div class="pmsg-av bot">H</div><div class="typing-dots"><span></span><span></span><span></span></div>`;
    document.getElementById('panelMessages').appendChild(d);
    scrollPanel();
  }

  function removePanelTyping() { const t = document.getElementById('ptyping'); if(t) t.remove(); }
  function scrollPanel() { const m = document.getElementById('panelMessages'); m.scrollTop = m.scrollHeight; }
  function esc(t) { return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function fmt(t) {
    return t.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
            .replace(/\*(.+?)\*/g,'<em>$1</em>')
            .replace(/^- (.+)$/gm,'• $1')
            .replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>');
  }

  document.getElementById('panelInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); panelSend(); }
  });
</script>
</body>
