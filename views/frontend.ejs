<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CampusHire — Ace Your Placements</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    :root {
      --navy: #0a0f2c;
      --navy2: #111936;
      --blue: #2563eb;
      --blue2: #1d4ed8;
      --accent: #38bdf8;
      --accent2: #0ea5e9;
      
      --white: #ffffff;
      --offwhite: #f8faff;
      --border: #e2e8f0;
      --muted: #64748b;
      --text: #0f172a;
      --card: #ffffff;
      --radius: 16px;
      --shadow: 0 4px 24px rgba(0,0,0,0.07);
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--offwhite); color: var(--text); overflow-x: hidden; }

    /* ─── NAVBAR ─── */
    .navbar {
      position: sticky; top: 0; z-index: 200;
      height: 64px;
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px;
    }
    .logo {
      font-family: 'Sora', sans-serif;
      font-weight: 800; font-size: 20px;
      color: var(--navy); letter-spacing: -0.5px;
      display: flex; align-items: center; gap: 8px;
    }
    .logo-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--blue); }
    .logo span { color: var(--blue); }
    .nav-links { display: flex; align-items: center; gap: 4px; }
    .nav-links a {
      text-decoration: none; color: var(--muted);
      font-size: 14px; font-weight: 500;
      padding: 7px 14px; border-radius: 9px; transition: all 0.2s;
    }
    .nav-links a:hover { background: var(--offwhite); color: var(--text); }
    .nav-links a.active { color: var(--blue); background: #eff6ff; }
    .nav-cta {
      background: var(--navy); color: white;
      padding: 9px 20px; border-radius: 10px;
      text-decoration: none; font-size: 14px; font-weight: 600;
      font-family: 'Sora', sans-serif;
      transition: background 0.2s;
    }
    .nav-cta:hover { background: var(--blue); }

    /* ─── HERO ─── */
    .hero {
      background: var(--navy);
      color: white;
      padding: 96px 40px 110px;
      text-align: center;
      position: relative; overflow: hidden;
    }
    .hero-glow {
      position: absolute; border-radius: 50%;
      background: radial-gradient(circle, rgba(56,189,248,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .glow1 { width: 700px; height: 700px; top: -300px; left: -150px; }
    .glow2 { width: 500px; height: 500px; bottom: -200px; right: -100px; background: radial-gradient(circle, rgba(37,99,235,0.2) 0%, transparent 70%); }

    .hero-pill {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 16px; border-radius: 50px;
      border: 1px solid rgba(56,189,248,0.35);
      background: rgba(56,189,248,0.08);
      font-size: 13px; color: var(--accent);
      font-weight: 500; margin-bottom: 28px;
      position: relative; z-index: 1;
    }
    .hero-pill-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.4)} }

    .hero h1 {
      font-family: 'Sora', sans-serif;
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 800; line-height: 1.12;
      margin-bottom: 22px; letter-spacing: -1px;
      position: relative; z-index: 1;
    }
    .hero h1 .hl { color: var(--accent); }
    .hero p {
      max-width: 560px; margin: 0 auto 38px;
      color: #94a3b8; font-size: 16px; line-height: 1.7;
      position: relative; z-index: 1;
    }
    .hero-btns {
      display: flex; justify-content: center; gap: 12px;
      flex-wrap: wrap; position: relative; z-index: 1;
    }
    .btn-primary {
      background: var(--blue); color: white;
      padding: 13px 28px; border-radius: 11px;
      text-decoration: none; font-weight: 600; font-size: 15px;
      font-family: 'Sora', sans-serif;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-primary:hover { background: var(--blue2); transform: translateY(-1px); }
    .btn-ghost {
      border: 1.5px solid rgba(255,255,255,0.25); color: white;
      padding: 13px 28px; border-radius: 11px;
      text-decoration: none; font-weight: 600; font-size: 15px;
      font-family: 'Sora', sans-serif;
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-ghost:hover { border-color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.06); }

    .hero-trust {
      margin-top: 48px; position: relative; z-index: 1;
      display: flex; align-items: center; justify-content: center; gap: 28px;
      font-size: 13px; color: #64748b;
    }
    .trust-item { display: flex; align-items: center; gap: 6px; }
    .trust-sep { width: 1px; height: 16px; background: rgba(255,255,255,0.1); }

    /* ─── STATS STRIP ─── */
    .stats-strip {
      background: white;
      border-bottom: 1px solid var(--border);
      display: flex; justify-content: center;
    }
    .stats-inner {
      display: flex; max-width: 900px; width: 100%;
    }
    .stat-item {
      flex: 1; padding: 32px 20px; text-align: center;
      border-right: 1px solid var(--border);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-family: 'Sora', sans-serif;
      font-size: 2rem; font-weight: 800;
      color: var(--navy); letter-spacing: -1px;
    }
    .stat-num span { color: var(--blue); }
    .stat-label { font-size: 13px; color: var(--muted); margin-top: 4px; font-weight: 500; }

    /* ─── SECTION WRAPPER ─── */
    .section { padding: 72px 40px; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-header { text-align: center; margin-bottom: 48px; }
    .section-tag {
      display: inline-block; font-size: 12px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--blue); background: #eff6ff;
      padding: 5px 14px; border-radius: 50px; margin-bottom: 14px;
    }
    .section-header h2 {
      font-family: 'Sora', sans-serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      font-weight: 700; color: var(--navy); letter-spacing: -0.5px;
    }
    .section-header p { color: var(--muted); font-size: 15px; margin-top: 10px; }

    /* ─── CATEGORIES ─── */
    .cat-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
    }
    .cat-card {
      padding: 28px 20px; border-radius: var(--radius);
      text-align: center; cursor: pointer;
      border: 1.5px solid transparent;
      transition: all 0.22s; text-decoration: none; display: block;
    }
    .cat-card:hover { transform: translateY(-5px); box-shadow: 0 12px 32px rgba(0,0,0,0.1); }
    .cat-icon { font-size: 2rem; margin-bottom: 12px; display: block; }
    .cat-name { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 15px; color: var(--navy); }
    .cat-desc { font-size: 13px; color: var(--muted); margin-top: 5px; }

    /* ─── FEATURES ─── */
    .features-section { background: white; }
    .feat-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px; }
    .feat-card {
      background: var(--offwhite); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 28px;
      display: flex; gap: 18px; align-items: flex-start;
      transition: box-shadow 0.2s, border-color 0.2s;
    }
    .feat-card:hover { border-color: #bfdbfe; box-shadow: var(--shadow); }
    .feat-icon-box {
      width: 48px; height: 48px; border-radius: 12px;
      background: #eff6ff; display: flex; align-items: center;
      justify-content: center; font-size: 22px; flex-shrink: 0;
    }
    .feat-card h4 { font-family: 'Sora', sans-serif; font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
    .feat-card p { font-size: 14px; color: var(--muted); line-height: 1.6; }

    /* ─── COMPANIES ─── */
    .companies-section { background: var(--offwhite); }
    .co-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 28px; }
    .co-header h2 { font-family: 'Sora', sans-serif; font-size: 1.5rem; font-weight: 700; color: var(--navy); }
    .co-header a { font-size: 14px; font-weight: 600; color: var(--blue); text-decoration: none; }
    .co-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
    .co-card {
      background: white; border: 1px solid var(--border);
      border-radius: var(--radius); padding: 22px;
      cursor: pointer; transition: all 0.22s; text-decoration: none; display: block;
    }
    .co-card:hover { transform: translateY(-4px); box-shadow: 0 12px 28px rgba(0,0,0,0.08); border-color: #bfdbfe; }
    .co-logo {
      width: 44px; height: 44px; border-radius: 11px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Sora', sans-serif;
      color: white; font-weight: 800; font-size: 14px; margin-bottom: 14px;
    }
    .co-card h3 { font-family: 'Sora', sans-serif; font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 3px; }
    .co-card .co-q { font-size: 13px; color: var(--muted); margin-bottom: 12px; }
    .pill {
      display: inline-block; padding: 3px 11px;
      border-radius: 50px; font-size: 12px; font-weight: 600;
    }
    .pill.hard { background: #fee2e2; color: #b91c1c; }
    .pill.medium { background: #fef3c7; color: #b45309; }
    .pill.easy { background: #dcfce7; color: #15803d; }

    /* ─── WHY SECTION ─── */
    .why-section {
      background: var(--navy); color: white;
      padding: 80px 40px;
    }
    .why-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 60px; align-items: center; }
    .why-left { flex: 1; }
    .why-left .section-tag { background: rgba(56,189,248,0.12); color: var(--accent); }
    .why-left h2 { font-family: 'Sora', sans-serif; font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; line-height: 1.3; margin-bottom: 18px; }
    .why-left h2 span { color: var(--accent); }
    .why-left p { color: #94a3b8; font-size: 15px; line-height: 1.7; margin-bottom: 28px; }
    .why-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .why-list li { display: flex; align-items: center; gap: 10px; font-size: 14px; color: #cbd5e1; }
    .check-icon {
      width: 20px; height: 20px; border-radius: 50%;
      background: rgba(56,189,248,0.15); border: 1px solid rgba(56,189,248,0.3);
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; color: var(--accent); flex-shrink: 0;
    }
    .why-right { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .why-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px; padding: 24px;
      transition: background 0.2s;
    }
    .why-card:hover { background: rgba(255,255,255,0.08); }
    .why-card .wc-num {
      font-family: 'Sora', sans-serif; font-size: 1.8rem; font-weight: 800;
      color: var(--accent); margin-bottom: 4px;
    }
    .why-card h3 { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
    .why-card p { font-size: 12px; color: #94a3b8; }

    /* ─── FOOTER ─── */
    .footer { background: #060c20; color: #64748b; padding: 56px 40px 28px; }
    .footer-inner { max-width: 1100px; margin: 0 auto; }
    .footer-top { display: flex; justify-content: space-between; gap: 40px; margin-bottom: 40px; flex-wrap: wrap; }
    .footer-brand .logo { margin-bottom: 12px; display: flex; }
    .footer-brand p { font-size: 14px; line-height: 1.6; max-width: 220px; }
    .footer-col h4 { color: white; font-size: 14px; font-weight: 600; margin-bottom: 14px; }
    .footer-col a { display: block; color: #64748b; text-decoration: none; font-size: 14px; margin-bottom: 8px; transition: color 0.2s; }
    .footer-col a:hover { color: white; }
    .footer-bottom { border-top: 1px solid #1e293b; padding-top: 22px; text-align: center; font-size: 13px; color: #334155; }

    /* ─── CHATBOT BUBBLE ─── */
    .chat-bubble {
      position: fixed; bottom: 28px; right: 28px; z-index: 999;
      width: 60px; height: 60px; border-radius: 50%;
      background: var(--blue);
      border: none; cursor: pointer;
      box-shadow: 0 4px 20px rgba(37,99,235,0.45);
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .chat-bubble:hover { transform: scale(1.08); box-shadow: 0 6px 28px rgba(37,99,235,0.55); }
    .chat-bubble svg { width: 26px; height: 26px; fill: white; transition: opacity 0.2s; }
    .bubble-badge {
      position: absolute; top: -4px; right: -4px;
      width: 18px; height: 18px; border-radius: 50%;
      background: #ef4444; border: 2px solid white;
      font-size: 10px; font-weight: 700; color: white;
      display: flex; align-items: center; justify-content: center;
    }
    .chat-tooltip {
      position: absolute; bottom: 72px; right: 0;
      background: var(--navy); color: white;
      font-size: 13px; font-weight: 500;
      padding: 8px 14px; border-radius: 10px;
      white-space: nowrap; pointer-events: none;
      opacity: 0; transform: translateY(6px);
      transition: all 0.2s;
    }
    .chat-bubble:hover .chat-tooltip { opacity: 1; transform: translateY(0); }

    /* ─── CHAT PANEL ─── */
    .chat-panel {
      position: fixed; bottom: 100px; right: 28px; z-index: 998;
      width: 380px; max-height: 560px;
      background: white; border: 1px solid var(--border);
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.15);
      display: flex; flex-direction: column;
      overflow: hidden;
      transform: scale(0.92) translateY(20px);
      opacity: 0; pointer-events: none;
      transform-origin: bottom right;
      transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
    }
    .chat-panel.open {
      transform: scale(1) translateY(0);
      opacity: 1; pointer-events: all;
    }

    .panel-header {
      background: var(--navy); padding: 16px 18px;
      display: flex; align-items: center; gap: 12px;
    }
    .panel-avatar {
      width: 38px; height: 38px; border-radius: 11px;
      background: var(--blue);
      display: flex; align-items: center; justify-content: center;
    }
    .panel-avatar svg { width: 20px; height: 20px; fill: white; }
    .panel-info { flex: 1; }
    .panel-info p { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 14px; color: white; }
    .panel-info span { font-size: 12px; color: #94a3b8; display: flex; align-items: center; gap: 5px; }
    .online { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; }
    .panel-close {
      background: none; border: none; cursor: pointer;
      color: #94a3b8; font-size: 20px; line-height: 1;
      transition: color 0.2s; padding: 4px;
    }
    .panel-close:hover { color: white; }

    .panel-messages {
      flex: 1; overflow-y: auto; padding: 16px;
      display: flex; flex-direction: column; gap: 12px;
      background: #f8faff; min-height: 260px; max-height: 320px;
    }

    .pmsg { display: flex; gap: 8px; align-items: flex-end; }
    .pmsg.user { flex-direction: row-reverse; }

    .pmsg-av {
      width: 28px; height: 28px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700; flex-shrink: 0;
    }
    .pmsg-av.bot { background: #eff6ff; color: var(--blue); }
    .pmsg-av.usr { background: #f1f5f9; color: var(--muted); }

    .pmsg-text {
      max-width: 78%; padding: 10px 13px;
      border-radius: 13px; font-size: 13px; line-height: 1.55;
    }
    .pmsg.bot .pmsg-text {
      background: white; border: 1px solid var(--border);
      color: var(--text); border-bottom-left-radius: 4px;
    }
    .pmsg.user .pmsg-text {
      background: var(--blue); color: white;
      border-bottom-right-radius: 4px;
    }

    .typing-dots {
      display: flex; gap: 4px;
      padding: 12px 14px; background: white;
      border: 1px solid var(--border); border-radius: 13px;
      border-bottom-left-radius: 4px; width: fit-content;
    }
    .typing-dots span {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--blue); opacity: 0.4;
      animation: tdot 1.2s infinite;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes tdot { 0%,80%,100%{transform:translateY(0);opacity:.4} 40%{transform:translateY(-5px);opacity:1} }

    .upload-prompt {
      background: #eff6ff; border: 1.5px dashed #bfdbfe;
      border-radius: 11px; padding: 14px 16px; margin: 4px 0;
      text-align: center; cursor: pointer; transition: all 0.2s;
    }
    .upload-prompt:hover { border-color: var(--blue); background: #dbeafe; }
    .upload-prompt p { font-size: 13px; color: var(--blue); font-weight: 600; }
    .upload-prompt small { font-size: 11px; color: var(--muted); }

    .file-ok {
      background: #dcfce7; border: 1px solid #86efac;
      border-radius: 10px; padding: 10px 14px;
      font-size: 13px; color: #15803d; font-weight: 500;
      display: flex; align-items: center; gap: 8px;
    }

    .panel-quick {
      padding: 10px 14px 0;
      display: flex; flex-wrap: wrap; gap: 6px;
    }
    .pquick {
      font-size: 12px; padding: 5px 11px;
      border: 1px solid var(--border); border-radius: 20px;
      background: white; color: var(--text);
      cursor: pointer; transition: all 0.18s;
      font-family: 'DM Sans', sans-serif;
    }
    .pquick:hover { border-color: var(--blue); color: var(--blue); background: #eff6ff; }

    .panel-input-row {
      padding: 12px 14px; border-top: 1px solid var(--border);
      display: flex; gap: 8px; background: white;
    }
    .panel-input {
      flex: 1; padding: 9px 13px;
      border: 1px solid var(--border); border-radius: 10px;
      font-size: 13px; font-family: 'DM Sans', sans-serif;
      outline: none; transition: border-color 0.2s; color: var(--text);
      background: var(--offwhite);
    }
    .panel-input:focus { border-color: var(--blue); }
    .panel-input::placeholder { color: #94a3b8; }
    .panel-send {
      background: var(--blue); border: none; border-radius: 10px;
      width: 38px; height: 38px; display: flex;
      align-items: center; justify-content: center;
      cursor: pointer; transition: background 0.2s, transform 0.1s; flex-shrink: 0;
    }
    .panel-send:hover { background: var(--blue2); }
    .panel-send:active { transform: scale(0.95); }
    .panel-send svg { width: 16px; height: 16px; fill: white; }
    .panel-send:disabled { background: #94a3b8; cursor: not-allowed; }

    #resumeInput { display: none; }

    @media (max-width: 768px) {
      .navbar { padding: 0 16px; }
      .nav-links { display: none; }
      .hero { padding: 64px 20px 72px; }
      .section { padding: 56px 20px; }
      .cat-grid { grid-template-columns: repeat(2,1fr); }
      .feat-grid { grid-template-columns: 1fr; }
      .co-grid { grid-template-columns: repeat(2,1fr); }
      .why-inner { flex-direction: column; gap: 36px; }
      .why-right { grid-template-columns: 1fr 1fr; }
      .stats-inner { flex-wrap: wrap; }
      .stat-item { min-width: 50%; border-right: none; border-bottom: 1px solid var(--border); }
      .chat-panel { width: calc(100vw - 32px); right: 16px; bottom: 90px; }
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="logo">
    <div class="logo-dot"></div>
    Campus<span>Hire</span>
  </div>
  <div class="nav-links">
    <a href="/" class="active">Home</a>
    <a href="/prepare">Companies</a>
    <a href="/experiences">Alumni Experiences</a>
    <a href="/analytics">Analytics</a>
    <a href="/dashboard">My Dashboard</a>
  </div>
  <a href="/prepare" class="nav-cta">Start Preparing →</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow glow1"></div>
  <div class="hero-glow glow2"></div>
  <div class="hero-pill">
    <span class="hero-pill-dot"></span>
    Trusted by 12,500+ students across India
  </div>
  <h1>Ace Your Campus Placements<br>with <span class="hl">Real Interview Data</span></h1>
  <p>Access company-specific question banks built from real experiences of placed seniors. Prepare smarter, not harder.</p>
  <div class="hero-btns">
    <a href="/prepare" class="btn-primary">Explore Companies →</a>
    <a href="/question-bank" class="btn-ghost">Browse Questions</a>
  </div>
  <div class="hero-trust">
    <div class="trust-item">✦ 50+ Companies</div>
    <div class="trust-sep"></div>
    <div class="trust-item">✦ 2,800+ Questions</div>
    <div class="trust-sep"></div>
    <div class="trust-item">✦ 73% Placement Rate</div>
  </div>
</section>

<!-- STATS -->
<div class="stats-strip">
  <div class="stats-inner">
    <div class="stat-item">
      <div class="stat-num">50<span>+</span></div>
      <div class="stat-label">Companies covered</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">2.8<span>K+</span></div>
