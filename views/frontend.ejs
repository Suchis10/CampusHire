<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Campus Hire</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&display=swap" rel="stylesheet">

<style>
*{ margin:0; padding:0; box-sizing:border-box; font-family:'Sora', sans-serif; }

body{ background:#f1f5f9; }

/* ── NAVBAR ── */
.navbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:0 40px;
  height:64px;
  background:#fff;
  border-bottom:1px solid #e2e8f0;
  position:sticky;
  top:0;
  z-index:100;
  box-shadow:0 1px 8px rgba(0,0,0,0.06);
}

.logo{ font-size:20px; font-weight:700; color:#0f172a; letter-spacing:-0.5px; }
.logo span{ color:#2563eb; }

.nav-links{ display:flex; align-items:center; gap:6px; }
.nav-links a{
  text-decoration:none;
  color:#64748b;
  font-size:14px;
  font-weight:600;
  padding:7px 14px;
  border-radius:8px;
  transition:all 0.2s;
}
.nav-links a:hover{ background:#f1f5f9; color:#0f172a; }

/* Dashboard link styled differently */
.nav-links a.dashboard-link{
  color:#2563eb;
  background:#eff6ff;
}
.nav-links a.dashboard-link:hover{ background:#dbeafe; }

.nav-right{ display:flex; align-items:center; gap:10px; }

.cta{
  background:linear-gradient(135deg,#2563eb,#4f46e5);
  color:#fff;
  padding:9px 20px;
  border-radius:9px;
  text-decoration:none;
  font-size:14px;
  font-weight:600;
  transition:opacity 0.2s;
}
.cta:hover{ opacity:0.9; }

/* ── HERO ── */
.hero{
  background:linear-gradient(135deg,#0f172a,#1e2a5a,#3b3fbf);
  color:white;
  text-align:center;
  padding:90px 20px 100px;
  position:relative;
  overflow:hidden;
}

.hero::before{
  content:'';
  position:absolute;
  width:600px; height:600px;
  background:rgba(99,102,241,0.15);
  border-radius:50%;
  top:-200px; left:-100px;
}
.hero::after{
  content:'';
  position:absolute;
  width:400px; height:400px;
  background:rgba(37,99,235,0.1);
  border-radius:50%;
  bottom:-150px; right:-50px;
}

.hero-badge{
  display:inline-block;
  padding:7px 18px;
  border-radius:50px;
  border:1px solid rgba(147,197,253,0.4);
  background:rgba(255,255,255,0.08);
  margin-bottom:22px;
  font-size:13px;
  color:#93c5fd;
  position:relative;
  z-index:1;
}

.hero h1{
  font-size:52px;
  line-height:1.15;
  margin:0 0 20px;
  position:relative;
  z-index:1;
}
.hero h1 span{ color:#60a5fa; }

.hero p{
  max-width:620px;
  margin:0 auto 32px;
  color:#c7d2fe;
  font-size:16px;
  line-height:1.7;
  position:relative;
  z-index:1;
}

.hero-btns{ display:flex; justify-content:center; gap:14px; position:relative; z-index:1; }

.primary{
  background:#3b82f6;
  color:white;
  padding:13px 26px;
  border-radius:10px;
  text-decoration:none;
  font-weight:600;
  font-size:15px;
  transition:background 0.2s;
}
.primary:hover{ background:#2563eb; }

.secondary{
  border:1.5px solid rgba(255,255,255,0.4);
  color:white;
  padding:13px 26px;
  border-radius:10px;
  text-decoration:none;
  font-weight:600;
  font-size:15px;
  transition:background 0.2s;
}
.secondary:hover{ background:rgba(255,255,255,0.1); }

/* ── STATS ── */
.stats{
  display:flex;
  justify-content:center;
  gap:20px;
  padding:40px;
  background:linear-gradient(#1e3a8a,#2d3e8b);
}
.stat-box{
  background:rgba(255,255,255,0.1);
  border:1px solid rgba(255,255,255,0.15);
  padding:28px 40px;
  border-radius:16px;
  text-align:center;
  color:white;
  flex:1;
  max-width:220px;
}
.stat-box h2{ font-size:32px; font-weight:700; }
.stat-box p{ color:#bfdbfe; font-size:14px; margin-top:4px; }

/* ── SECTION ── */
.section{ padding:70px 60px; text-align:center; }
.section h2{ font-size:30px; color:#0f172a; margin-bottom:10px; }
.section .sub{ color:#64748b; font-size:15px; margin-bottom:36px; }

/* ── CATEGORIES ── */
.categories{
  display:flex;
  justify-content:center;
  gap:18px;
  flex-wrap:wrap;
}
.cat-card{
  padding:28px 32px;
  border-radius:16px;
  width:180px;
  cursor:pointer;
  font-weight:600;
  font-size:15px;
  color:#0f172a;
  border:1.5px solid transparent;
  transition:all 0.2s;
}
.cat-card:hover{ transform:translateY(-4px); box-shadow:0 8px 24px rgba(0,0,0,0.1); }
.cat-card .icon{ font-size:28px; margin-bottom:10px; }

/* ── FEATURES ── */
.features{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:18px;
  margin-top:10px;
  text-align:left;
}
.feature-box{
  background:#fff;
  padding:26px;
  border-radius:14px;
  border:1px solid #e2e8f0;
  display:flex;
  align-items:flex-start;
  gap:14px;
}
.feature-box .ficon{
  font-size:26px;
  background:#eff6ff;
  padding:10px;
  border-radius:10px;
}
.feature-box h4{ font-size:15px; color:#0f172a; margin-bottom:4px; }
.feature-box p{ font-size:13px; color:#64748b; line-height:1.5; }

/* ── COMPANIES ── */
.company-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:20px;
  margin-top:10px;
  text-align:left;
}
.company-card{
  background:#fff;
  padding:24px;
  border-radius:16px;
  cursor:pointer;
  border:1px solid #e2e8f0;
  transition:all 0.25s;
}
.company-card:hover{
  transform:translateY(-5px);
  box-shadow:0 12px 28px rgba(0,0,0,0.09);
  border-color:#bfdbfe;
}
.logo-circle{
  width:48px; height:48px;
  border-radius:12px;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white;
  font-weight:700;
  font-size:16px;
  margin-bottom:14px;
}
.company-card h3{ font-size:15px; color:#0f172a; margin-bottom:4px; }
.company-card p{ color:#94a3b8; font-size:13px; margin-bottom:10px; }

.badge-pill{
  padding:4px 12px;
  border-radius:50px;
  font-size:12px;
  font-weight:600;
}
.badge-pill.hard{ background:#fee2e2; color:#dc2626; }
.badge-pill.medium{ background:#fef3c7; color:#d97706; }
.badge-pill.easy{ background:#dcfce7; color:#16a34a; }

/* ── WHY ── */
.why-section{
  margin:0 50px 60px;
  padding:60px;
  border-radius:24px;
  background:linear-gradient(135deg,#1e40af,#4f46e5);
  color:white;
  display:flex;
  justify-content:space-between;
  gap:40px;
  align-items:center;
}
.why-left{ width:45%; }
.why-left h2{ font-size:30px; line-height:1.3; }
.why-left h2 span{ color:#93c5fd; }
.why-left p{ margin:18px 0; line-height:1.7; color:#c7d2fe; font-size:15px; }
.why-left ul{ list-style:none; display:flex; flex-direction:column; gap:10px; }
.why-left li{ font-size:14px; color:#e0e7ff; }

.why-right{
  width:50%;
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:16px;
}
.why-card{
  background:rgba(255,255,255,0.1);
  border:1px solid rgba(255,255,255,0.15);
  padding:22px;
  border-radius:14px;
}
.why-card h3{ font-size:16px; margin-bottom:6px; }
.why-card p{ font-size:13px; color:#c7d2fe; }

/* ── FOOTER ── */
.footer{ background:#0f172a; color:#94a3b8; padding:50px 60px 30px; }
.footer-container{ display:flex; justify-content:space-between; gap:40px; margin-bottom:36px; }
.footer h3{ color:#fff; font-size:15px; margin-bottom:14px; }
.footer p{ font-size:14px; line-height:1.6; }
.footer a{ display:block; color:#94a3b8; text-decoration:none; margin:6px 0; font-size:14px; transition:color 0.2s; }
.footer a:hover{ color:#fff; }
.footer-bottom{ border-top:1px solid #1e293b; padding-top:20px; text-align:center; font-size:13px; color:#475569; }
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">🎓 Campus<span>Hire</span></div>

  <div class="nav-links">
    <a href="/">Home</a>
    <a href="/prepare">Companies</a>
    <a href="/question-bank">Question Bank</a>
    <a href="/analytics">Analytics</a>
    <a href="/dashboard" class="dashboard-link">📊 My Dashboard</a>
  </div>

  <div class="nav-right">
    <a href="/prepare" class="cta">Start Preparing →</a>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-badge">⭐ Trusted by 12,500+ students across India</div>
  <h1>Ace Your Campus Placements<br>with <span>Real Interview Data</span></h1>
  <p>Access company-specific question banks and prepare smarter using real experiences from placed seniors.</p>
  <div class="hero-btns">
    <a href="/prepare" class="primary">Explore Companies →</a>
    <a href="/question-bank" class="secondary">Browse Questions</a>
  </div>
</div>

<!-- STATS -->
<div class="stats">
  <div class="stat-box"><h2>50+</h2><p>Companies</p></div>
  <div class="stat-box"><h2>2.8K+</h2><p>Questions</p></div>
  <div class="stat-box"><h2>13K+</h2><p>Students</p></div>
  <div class="stat-box"><h2>73%</h2><p>Placement Rate</p></div>
</div>

<!-- CATEGORIES -->
<div class="section">
  <h2>Preparation Categories</h2>
  <p class="sub">Pick your focus area and start practicing today</p>

  <div class="categories">
    <div class="cat-card" style="background:#fef3c7; border-color:#fde68a;" onclick="location.href='/questions?cat=aptitude'">
      <div class="icon">🧮</div> Aptitude
    </div>
    <div class="cat-card" style="background:#dbeafe; border-color:#bfdbfe;" onclick="location.href='/questions?cat=dsa'">
      <div class="icon">💻</div> Coding DSA
    </div>
    <div class="cat-card" style="background:#ede9fe; border-color:#ddd6fe;" onclick="location.href='/questions?cat=tech'">
      <div class="icon">⚙️</div> Technical
    </div>
    <div class="cat-card" style="background:#dcfce7; border-color:#bbf7d0;" onclick="location.href='/questions?cat=hr'">
      <div class="icon">🤝</div> HR Questions
    </div>
  </div>
</div>

<!-- FEATURES -->
<div class="section" style="background:#fff; padding:70px 100px;">
  <h2>Everything You Need to Get Placed</h2>
  <p class="sub">All your placement tools in one place</p>

  <div class="features">
    <div class="feature-box">
      <div class="ficon">🏢</div>
      <div>
        <h4>Company Question Banks</h4>
        <p>Real questions asked in campus drives, filtered by company and role.</p>
      </div>
    </div>
    <div class="feature-box">
      <div class="ficon">📊</div>
      <div>
        <h4>Placement Analytics</h4>
        <p>Visualize hiring trends, difficulty levels, and package data.</p>
      </div>
    </div>
    <div class="feature-box">
      <div class="ficon">🤖</div>
      <div>
        <h4>AI-Ready Preparation</h4>
        <p>Smart tips and topic recommendations based on your progress.</p>
      </div>
    </div>
    <div class="feature-box">
      <div class="ficon">👨‍🎓</div>
      <div>
        <h4>Senior Insights</h4>
        <p>Learn from students who cracked interviews at top companies.</p>
      </div>
    </div>
  </div>
</div>

<!-- COMPANIES -->
<div class="section">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
    <div style="text-align:left;">
      <h2 style="margin-bottom:4px;">Top Companies</h2>
      <p style="color:#64748b; font-size:14px;">Click a company to explore its questions</p>
    </div>
    <a href="/companies" style="color:#2563eb; text-decoration:none; font-weight:600; font-size:14px;">View all →</a>
  </div>

  <div class="company-grid">
    <% const companies = [
      {name:"Google",       q:148, level:"Hard",   color:"#4285F4", letter:"G"},
      {name:"Microsoft",    q:132, level:"Hard",   color:"#00A4EF", letter:"M"},
      {name:"Amazon",       q:165, level:"Hard",   color:"#FF9900", letter:"A"},
      {name:"Infosys",      q:210, level:"Medium", color:"#007CC3", letter:"I"},
      {name:"TCS",          q:245, level:"Medium", color:"#E60000", letter:"T"},
      {name:"Wipro",        q:198, level:"Easy",   color:"#5A2D82", letter:"W"},
      {name:"Goldman Sachs",q:89,  level:"Hard",   color:"#6FA8DC", letter:"GS"},
      {name:"Deloitte",     q:156, level:"Medium", color:"#86BC25", letter:"D"}
    ]; %>

    <% companies.forEach(function(c) { %>
  <div class="company-card" onclick="location.href='/questions/<%= c.name %>'">
    <h3><%= c.name %></h3>
    <p><%= c.q %> questions</p>
    <span class="badge-pill <%= c.level.toLowerCase() %>"><%= c.level %></span>
  </div>
<% }); %>
  </div>
</div>

<!-- WHY -->
<div class="why-section">
  <div class="why-left">
    <h2>Why <span>CampusHire?</span></h2>
    <p>We convert unstructured placement experiences into a structured knowledge repository, reducing information asymmetry and helping every student prepare with equal access to insider knowledge.</p>
    <ul>
      <li>✔ Company-specific, verified question banks</li>
      <li>✔ Real trends from actual hiring seasons</li>
      <li>✔ Analytics to identify high-demand skills</li>
      <li>✔ Collaborative platform updated by seniors</li>
    </ul>
  </div>

  <div class="why-right">
    <div class="why-card">
      <h3>📈 Placement Trends</h3>
      <p>Year-over-year hiring analytics</p>
    </div>
    <div class="why-card">
      <h3>🏢 50+ Companies</h3>
      <p>FAANG to mass recruiters</p>
    </div>
    <div class="why-card">
      <h3>📚 2840+ Questions</h3>
      <p>Verified by placed seniors</p>
    </div>
    <div class="why-card">
      <h3>👨‍🎓 12K+ Students</h3>
      <p>Across institutions</p>
    </div>
  </div>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-container">
    <div>
      <h3>🎓 CampusHire</h3>
      <p>Your placement companion.<br>Built for students, by students.</p>
    </div>
    <div>
      <h3>Quick Links</h3>
      <a href="/">Home</a>
      <a href="/companies">Companies</a>
      <a href="/questions">Questions</a>
      <a href="/dashboard">My Dashboard</a>
    </div>
    <div>
      <h3>Resources</h3>
      <a href="#">Blog</a>
      <a href="#">Guides</a>
      <a href="#">Help</a>
    </div>
    <div>
      <h3>Contact</h3>
      <p>campushire@support.com</p>
    </div>
  </div>
  <div class="footer-bottom">© 2025 CampusHire. All rights reserved.</div>
</div>

</body>
</html>