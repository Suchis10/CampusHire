<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Alumni Dashboard – Campus Hire</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --blue-50:   #eff6ff;
      --blue-100:  #dbeafe;
      --blue-200:  #bfdbfe;
      --blue-400:  #60a5fa;
      --blue-500:  #3b82f6;
      --blue-600:  #2563eb;
      --blue-700:  #1d4ed8;
      --blue-900:  #1e3a8a;
      --slate-50:  #f8fafc;
      --slate-100: #f1f5f9;
      --slate-200: #e2e8f0;
      --slate-400: #94a3b8;
      --slate-500: #64748b;
      --slate-700: #334155;
      --slate-900: #0f172a;
      --green:     #10b981;
      --red:       #ef4444;
      --amber:     #f59e0b;
      --white:     #ffffff;
      --radius:    12px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--slate-100);
      color: var(--slate-900);
      font-family: 'Plus Jakarta Sans', sans-serif;
      min-height: 100vh;
    }

    /* ── TOPBAR ── */
    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--slate-200);
      padding: 0 2rem; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 100;
      box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }
    .logo { font-weight: 800; font-size: 1.3rem; letter-spacing: -0.5px; color: var(--slate-900); }
    .logo span { color: var(--blue-600); }
    .topbar-right { display: flex; align-items: center; gap: 1rem; }
    .badge-role {
      background: var(--blue-600); color: #fff; font-size: .7rem; font-weight: 700;
      padding: .28rem .75rem; border-radius: 20px; letter-spacing: .6px; text-transform: uppercase;
    }
    .btn-logout {
      background: transparent; border: 1.5px solid var(--slate-200);
      color: var(--slate-500); padding: .4rem 1rem;
      border-radius: 8px; cursor: pointer; font-size: .85rem;
      font-family: inherit; font-weight: 600; transition: .2s;
    }
    .btn-logout:hover { border-color: var(--red); color: var(--red); background: #fff5f5; }

    /* ── LAYOUT ── */
    .layout { display: grid; grid-template-columns: 224px 1fr; min-height: calc(100vh - 64px); }

    /* ── SIDEBAR ── */
    .sidebar {
      background: var(--white); border-right: 1px solid var(--slate-200);
      padding: 1.5rem 1rem; display: flex; flex-direction: column; gap: .25rem;
    }
    .sidebar-label {
      font-size: .68rem; font-weight: 700; color: var(--slate-400);
      text-transform: uppercase; letter-spacing: .8px;
      padding: .5rem 1rem .25rem; margin-top: .5rem;
    }
    .sidebar a {
      display: flex; align-items: center; gap: .7rem;
      padding: .6rem 1rem; border-radius: 9px;
      text-decoration: none; color: var(--slate-500);
      font-size: .875rem; font-weight: 600; transition: .15s;
    }
    .sidebar a:hover { background: var(--blue-50); color: var(--blue-600); }
    .sidebar a.active { background: var(--blue-600); color: #fff; box-shadow: 0 2px 8px rgba(37,99,235,.3); }
    .sidebar a .icon { font-size: 1rem; width: 20px; text-align: center; flex-shrink: 0; }

    /* sidebar button that opens modal instead of navigating */
    .sidebar-modal-btn {
      display: flex; align-items: center; gap: .7rem;
      padding: .6rem 1rem; border-radius: 9px;
      color: var(--slate-500); font-size: .875rem; font-weight: 600;
      cursor: pointer; background: none; border: none;
      font-family: inherit; width: 100%; text-align: left; transition: .15s;
    }
    .sidebar-modal-btn:hover { background: var(--blue-50); color: var(--blue-600); }
    .sidebar-modal-btn .icon { font-size: 1rem; width: 20px; text-align: center; flex-shrink: 0; }

    /* ── MAIN ── */
    .main { padding: 2rem 2.5rem; overflow-y: auto; }

    /* ── GREETING ── */
    .greeting { margin-bottom: 2rem; }
    .greeting h1 { font-size: 1.85rem; font-weight: 800; letter-spacing: -0.8px; color: var(--slate-900); }
    .greeting h1 span { color: var(--blue-600); }
    .greeting p { color: var(--slate-500); margin-top: .3rem; font-size: .95rem; }

    /* ── STAT CARDS ── */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card {
      background: var(--white); border: 1px solid var(--slate-200);
      border-radius: var(--radius); padding: 1.4rem 1.5rem;
      position: relative; overflow: hidden;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 1px 3px rgba(0,0,0,.05);
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(37,99,235,.1); }
    .stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .stat-card.c1::before { background: linear-gradient(90deg, var(--blue-500), var(--blue-400)); }
    .stat-card.c2::before { background: linear-gradient(90deg, var(--green), #34d399); }
    .stat-card.c3::before { background: linear-gradient(90deg, var(--amber), #fbbf24); }
    .stat-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; margin-bottom: .85rem; }
    .c1 .stat-icon { background: var(--blue-50); }
    .c2 .stat-icon { background: #ecfdf5; }
    .c3 .stat-icon { background: #fffbeb; }
    .stat-label { font-size: .72rem; color: var(--slate-400); text-transform: uppercase; letter-spacing: .5px; font-weight: 700; }
    .stat-value { font-size: 2rem; font-weight: 800; margin-top: .15rem; color: var(--slate-900); letter-spacing: -1px; }
    .stat-value.company-name { font-size: 1.15rem; letter-spacing: -0.3px; margin-top: .4rem; }
    .stat-sub { font-size: .78rem; color: var(--slate-400); margin-top: .1rem; font-weight: 500; }

    /* ── PROFILE CARD ── */
    .profile-card {
      background: linear-gradient(135deg, var(--blue-600) 0%, var(--blue-700) 100%);
      border-radius: var(--radius); padding: 1.6rem 2rem;
      display: flex; align-items: center; gap: 1.5rem;
      margin-bottom: 2rem; box-shadow: 0 4px 16px rgba(37,99,235,.25);
      position: relative; overflow: hidden;
    }
    .profile-card::after {
      content: ''; position: absolute; width: 200px; height: 200px;
      background: rgba(255,255,255,.06); border-radius: 50%; top: -60px; right: -40px;
    }
    .avatar {
      width: 62px; height: 62px; border-radius: 50%;
      background: rgba(255,255,255,.2); border: 2.5px solid rgba(255,255,255,.4);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem; font-weight: 800; color: #fff; flex-shrink: 0;
    }
    .profile-info h2 { font-size: 1.15rem; font-weight: 800; color: #fff; }
    .profile-meta { display: flex; gap: .6rem; margin-top: .5rem; flex-wrap: wrap; }
    .meta-chip {
      background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.25);
      border-radius: 20px; padding: .22rem .7rem;
      font-size: .73rem; color: rgba(255,255,255,.9); font-weight: 600;
    }

    /* ── ACTION BUTTONS ── */
    .actions { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: .72rem 1.4rem; border-radius: 9px;
      font-size: .88rem; font-weight: 700; text-decoration: none;
      cursor: pointer; border: none; transition: .2s; font-family: inherit;
    }
    .btn-primary { background: var(--blue-600); color: #fff; box-shadow: 0 2px 8px rgba(37,99,235,.3); }
    .btn-primary:hover { background: var(--blue-700); transform: translateY(-2px); }
    .btn-secondary { background: var(--white); color: var(--blue-600); border: 1.5px solid var(--blue-200); }
    .btn-secondary:hover { background: var(--blue-50); transform: translateY(-2px); }

    /* ── SECTION TITLE ── */
    .section-title {
      font-size: .95rem; font-weight: 800; margin-bottom: 1rem;
      display: flex; align-items: center; gap: .5rem; color: var(--slate-700);
    }
    .section-title .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--blue-600); display: inline-block; }

    /* ── TABLES ── */
    .table-wrap {
      background: var(--white); border: 1px solid var(--slate-200);
      border-radius: var(--radius); overflow: hidden; margin-bottom: 2rem;
      box-shadow: 0 1px 3px rgba(0,0,0,.05);
    }
    table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    thead { background: var(--slate-50); }
    th {
      padding: .85rem 1.2rem; text-align: left; font-size: .7rem;
      color: var(--slate-400); text-transform: uppercase; letter-spacing: .7px; font-weight: 700;
      border-bottom: 1px solid var(--slate-200);
    }
    td { padding: .9rem 1.2rem; border-bottom: 1px solid var(--slate-100); color: var(--slate-700); font-weight: 500; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--blue-50); }
    .diff-badge { display: inline-block; padding: .2rem .65rem; border-radius: 20px; font-size: .7rem; font-weight: 700; }
    .diff-easy   { background: #ecfdf5; color: var(--green); }
    .diff-medium { background: #fffbeb; color: var(--amber); }
    .diff-hard   { background: #fef2f2; color: var(--red); }
    .offer-yes { color: var(--green); font-weight: 700; }
    .offer-no  { color: var(--red); font-weight: 700; }
    .empty-state { padding: 3rem; text-align: center; color: var(--slate-400); font-size: .9rem; }
    .empty-state .icon { font-size: 2.2rem; margin-bottom: .6rem; }
    .empty-state p { font-weight: 600; }
    .lc-link { color: var(--blue-600); text-decoration: none; font-weight: 700; font-size: .8rem; }
    .lc-link:hover { text-decoration: underline; }
    .approach-text { font-size: .78rem; color: var(--slate-500); max-width: 240px; line-height: 1.4; }

    /* ══════════════════════════
       ADD QUESTION MODAL
    ══════════════════════════ */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(15,23,42,0.6);
      backdrop-filter: blur(5px);
      z-index: 2000;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none;
      transition: opacity 0.25s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }

    .modal {
      background: var(--white);
      border-radius: 20px;
      padding: 2.2rem 2.4rem;
      width: 100%; max-width: 600px;
      max-height: 92vh; overflow-y: auto;
      box-shadow: 0 32px 80px rgba(0,0,0,0.22);
      transform: translateY(30px) scale(0.97);
      transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
      position: relative;
    }
    .modal-overlay.open .modal { transform: translateY(0) scale(1); }

    .modal-header { margin-bottom: 1.6rem; padding-right: 2rem; }
    .modal-header h2 { font-size: 1.25rem; font-weight: 800; color: var(--slate-900); }
    .modal-header p { font-size: .85rem; color: var(--slate-500); margin-top: .3rem; }

    .modal-close {
      position: absolute; top: 1.2rem; right: 1.4rem;
      background: var(--slate-100); border: none; border-radius: 50%;
      width: 32px; height: 32px; cursor: pointer; color: var(--slate-500);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; transition: .2s;
    }
    .modal-close:hover { background: var(--red); color: #fff; }

    .form-group { margin-bottom: 1.1rem; }
    .form-group label {
      display: block; font-size: .72rem; font-weight: 700;
      color: var(--slate-700); text-transform: uppercase;
      letter-spacing: .6px; margin-bottom: .4rem;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%; padding: .7rem 1rem;
      border-radius: 9px; border: 1.5px solid var(--slate-200);
      font-size: .9rem; font-family: inherit;
      color: var(--slate-900); background: var(--white);
      outline: none; transition: border .2s; resize: vertical;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--blue-600);
      box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-hint { font-size: .72rem; color: var(--slate-400); margin-top: .3rem; font-style: italic; }

    .submit-btn {
      width: 100%; padding: .88rem;
      background: var(--blue-600); color: #fff;
      border: none; border-radius: 10px;
      font-size: .95rem; font-weight: 700; font-family: inherit;
      cursor: pointer; margin-top: .5rem; transition: .2s;
      display: flex; align-items: center; justify-content: center; gap: .5rem;
    }
    .submit-btn:hover { background: var(--blue-700); transform: translateY(-1px); }
    .submit-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }

    /* ── TOAST ── */
    .toast {
      position: fixed; bottom: 28px; left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: var(--slate-900); color: #fff;
      padding: .85rem 1.6rem; border-radius: 12px;
      font-size: .88rem; font-weight: 600;
      box-shadow: 0 8px 24px rgba(0,0,0,.2);
      z-index: 3000; white-space: nowrap;
      transition: transform 0.4s cubic-bezier(.34,1.56,.64,1);
    }
    .toast.show { transform: translateX(-50%) translateY(0); }
    .toast.success { border-left: 4px solid var(--green); }
    .toast.error   { border-left: 4px solid var(--red); }
  </style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="logo">Campus<span>Hire</span></div>
  <div class="topbar-right">
    <span class="badge-role">Alumni</span>
    <button class="btn-logout" onclick="window.location='/'">Logout</button>
  </div>
</div>

<div class="layout">

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="sidebar-label">Menu</div>
    <a href="/alumni/dashboard" class="active"><span class="icon">🏠</span> Dashboard</a>

    <!-- Opens modal, not a page -->
    <button class="sidebar-modal-btn" onclick="openModal()">
      <span class="icon">➕</span> Add Question
    </button>

    <a href="/alumni/share-experience"><span class="icon">📝</span> Share Experience</a>
    <div class="sidebar-label">Explore</div>
    <a href="/experiences"><span class="icon">🌐</span> All Experiences</a>
    <a href="/prepare"><span class="icon">📚</span> Prepare (Student)</a>
  </nav>

  <!-- MAIN -->
  <main class="main">

    <!-- Greeting -->
    <div class="greeting">
      <h1>Welcome back, <span><%= alumni.name.split(' ')[0] %></span> 👋</h1>
      <p>Your contributions help students crack their dream companies.</p>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card c1">
        <div class="stat-icon">❓</div>
        <div class="stat-label">Questions Added</div>
        <div class="stat-value" id="questionsCount"><%= stats.questionsAdded %></div>
        <div class="stat-sub">across all companies</div>
      </div>
      <div class="stat-card c2">
        <div class="stat-icon">📝</div>
        <div class="stat-label">Experiences Shared</div>
        <div class="stat-value"><%= stats.experiencesShared %></div>
        <div class="stat-sub">helping future students</div>
      </div>
      <div class="stat-card c3">
        <div class="stat-icon">💼</div>
        <div class="stat-label">Your Company</div>
        <div class="stat-value company-name"><%= alumni.company %></div>
        <div class="stat-sub"><%= alumni.jobRole %></div>
      </div>
    </div>

    <!-- Profile -->
    <div class="profile-card">
      <div class="avatar"><%= alumni.name.charAt(0).toUpperCase() %></div>
      <div class="profile-info">
        <h2><%= alumni.name %></h2>
        <div class="profile-meta">
          <span class="meta-chip">📧 <%= alumni.email %></span>
          <span class="meta-chip">🎓 Batch <%= alumni.batch %></span>
          <span class="meta-chip">🏛️ <%= alumni.branch %></span>
          <span class="meta-chip">💼 <%= alumni.jobRole %> @ <%= alumni.company %></span>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="actions">
      <button class="btn btn-primary" onclick="openModal()">➕ Add New Question</button>
      <a href="/alumni/share-experience" class="btn btn-secondary">📝 Share Experience</a>
    </div>

    <!-- My Questions -->
    <div class="section-title"><span class="dot"></span> Questions I've Added</div>
    <div class="table-wrap" id="questionsTableWrap">
      <% if (myQuestions.length === 0) { %>
        <div class="empty-state" id="questionsEmptyState">
          <div class="icon">📭</div>
          <p>No questions yet — click "Add New Question" to contribute!</p>
        </div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Question</th>
            <th>Company</th>
            <th>Category</th>
            <th>Difficulty</th>
            <th>Round</th>
            <th>Approach</th>
            <th>LeetCode</th>
          </tr>
        </thead>
        <tbody id="questionsBody">
          <% myQuestions.forEach((q, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td style="max-width:220px"><%= q.questionText %></td>
            <td style="text-transform:capitalize"><%= q.company %></td>
            <td><%= q.category %></td>
            <td>
              <span class="diff-badge diff-<%= q.difficulty ? q.difficulty.toLowerCase() : 'medium' %>">
                <%= q.difficulty || 'Medium' %>
              </span>
            </td>
            <td><%= q.round || '—' %></td>
            <td>
              <% if (q.approach) { %>
                <span class="approach-text"><%= q.approach.substring(0, 60) %><%= q.approach.length > 60 ? '…' : '' %></span>
              <% } else { %>
                <span style="color:var(--slate-400)">—</span>
              <% } %>
            </td>
            <td>
              <% if (q.leetcode) { %>
                <a href="<%= q.leetcode %>" target="_blank" class="lc-link">🔗 Link</a>
              <% } else { %>
                <span style="color:var(--slate-400)">—</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <!-- My Experiences -->
    <div class="section-title"><span class="dot"></span> Experiences I've Shared</div>
    <div class="table-wrap">
      <% if (myExperiences.length === 0) { %>
        <div class="empty-state">
          <div class="icon">📭</div>
          <p>You haven't shared any experiences yet.</p>
        </div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>#</th><th>Company</th><th>Role</th><th>Offer</th><th>CTC</th><th>Posted</th>
          </tr>
        </thead>
        <tbody>
          <% myExperiences.forEach((e, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= e.company %></td>
            <td><%= e.jobRole %></td>
            <td class="<%= e.offerReceived ? 'offer-yes' : 'offer-no' %>">
              <%= e.offerReceived ? '✅ Yes' : '❌ No' %>
            </td>
            <td><%= e.ctc %></td>
            <td><%= e.createdAt.toDateString() %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

  </main>
</div>


<!-- ══════════════════════════════════════════
     ADD QUESTION MODAL
══════════════════════════════════════════ -->
<div class="modal-overlay" id="modalOverlay" onclick="closeOnBackdrop(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>

    <div class="modal-header">
      <h2>➕ Add Interview Question</h2>
      <p>Share what you were asked — your experience helps the next batch crack it.</p>
    </div>

    <form id="addQuestionForm" onsubmit="submitQuestion(event)">

      <!-- Question -->
      <div class="form-group">
        <label>Question *</label>
        <textarea name="questionText" rows="3"
          placeholder="e.g. Given an array of integers, find two numbers that add up to a target sum..."
          required></textarea>
      </div>

      <!-- Company + Category -->
      <div class="form-row">
        <div class="form-group">
          <label>Company *</label>
          <input type="text" name="company"
            placeholder="e.g. Google, Amazon, TCS..." required>
          <div class="form-hint">Already on Prepare page? Question auto-adds there for students.</div>
        </div>
        <div class="form-group">
          <label>Category *</label>
          <select name="category" required>
            <option value="" disabled selected>Select category</option>
            <option>DSA</option>
            <option>Core CS</option>
            <option>System Design</option>
            <option>Aptitude</option>
            <option>HR</option>
            <option>Other</option>
          </select>
        </div>
      </div>

      <!-- Difficulty + Round -->
      <div class="form-row">
        <div class="form-group">
          <label>Difficulty *</label>
          <select name="difficulty" required>
            <option value="" disabled selected>Select difficulty</option>
            <option>Easy</option>
            <option>Medium</option>
            <option>Hard</option>
          </select>
        </div>
        <div class="form-group">
          <label>Round</label>
          <select name="round">
            <option value="">— Select round —</option>
            <option>Online Test</option>
            <option>Technical Round 1</option>
            <option>Technical Round 2</option>
            <option>HR Round</option>
            <option>Managerial Round</option>
          </select>
        </div>
      </div>

      <!-- Approach -->
      <div class="form-group">
        <label>Approach / Solution Hint</label>
        <textarea name="approach" rows="3"
          placeholder="e.g. Use a HashMap to store seen values. For each element check if (target - element) exists in the map. Time: O(n), Space: O(n)..."></textarea>
        <div class="form-hint">Optional but super helpful for students — share your thought process.</div>
      </div>

      <!-- LeetCode -->
      <div class="form-group">
        <label>LeetCode / Reference Link</label>
        <input type="url" name="leetcode"
          placeholder="https://leetcode.com/problems/two-sum/">
        <div class="form-hint">Optional — paste the problem URL so students can practice directly.</div>
      </div>

      <button type="submit" class="submit-btn" id="submitBtn">
        Submit Question →
      </button>
    </form>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>


<script>
  /* ── MODAL OPEN / CLOSE ── */
  function openModal() {
    document.getElementById('modalOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    document.getElementById('modalOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }
  function closeOnBackdrop(e) {
    if (e.target === document.getElementById('modalOverlay')) closeModal();
  }

  /* ── SUBMIT ── */
  async function submitQuestion(e) {
    e.preventDefault();
    const form = e.target;
    const btn  = document.getElementById('submitBtn');
    btn.textContent = 'Submitting…';
    btn.disabled = true;

    const payload = {
      questionText: form.questionText.value.trim(),
      company:      form.company.value.trim(),
      category:     form.category.value,
      difficulty:   form.difficulty.value,
      round:        form.round.value || '',
      approach:     form.approach.value.trim(),
      leetcode:     form.leetcode.value.trim(),
    };

    try {
      const res  = await fetch('/alumni/add-question', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });
      const data = await res.json();

      if (res.ok) {
        closeModal();
        form.reset();
        // ① bump the Questions Added counter
        const counter = document.getElementById('questionsCount');
        counter.textContent = parseInt(counter.textContent) + 1;
        // ② add new row to the table immediately
        appendRowToTable(payload);
        showToast('✅ Question added! Students can see it on the Prepare page.', 'success');
      } else {
        showToast('❌ ' + (data.message || 'Something went wrong.'), 'error');
      }
    } catch (err) {
      showToast('❌ Network error. Please try again.', 'error');
    }

    btn.textContent = 'Submit Question →';
    btn.disabled = false;
  }

  /* ── ADD ROW TO TABLE (live, no reload) ── */
  function appendRowToTable(q) {
    const wrap = document.getElementById('questionsTableWrap');

    // If it was showing the empty state, replace with a fresh table first
    const emptyState = document.getElementById('questionsEmptyState');
    if (emptyState) {
      wrap.innerHTML = `
        <table>
          <thead>
            <tr>
              <th>#</th><th>Question</th><th>Company</th>
              <th>Category</th><th>Difficulty</th><th>Round</th>
              <th>Approach</th><th>LeetCode</th>
            </tr>
          </thead>
          <tbody id="questionsBody"></tbody>
        </table>`;
    }

    const tbody    = document.getElementById('questionsBody');
    const rowNum   = tbody.querySelectorAll('tr').length + 1;
    const diffCls  = q.difficulty ? q.difficulty.toLowerCase() : 'medium';
    const lcCell   = q.leetcode
      ? `<a href="${q.leetcode}" target="_blank" class="lc-link">🔗 Link</a>`
      : `<span style="color:var(--slate-400)">—</span>`;
    const approach = q.approach
      ? `<span class="approach-text">${q.approach.substring(0,60)}${q.approach.length > 60 ? '…' : ''}</span>`
      : `<span style="color:var(--slate-400)">—</span>`;

    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${rowNum}</td>
      <td style="max-width:220px">${q.questionText}</td>
      <td style="text-transform:capitalize">${q.company}</td>
      <td>${q.category}</td>
      <td><span class="diff-badge diff-${diffCls}">${q.difficulty}</span></td>
      <td>${q.round || '—'}</td>
      <td>${approach}</td>
      <td>${lcCell}</td>
    `;
    tbody.appendChild(tr);
  }

  /* ── TOAST ── */
  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = `toast ${type} show`;
    setTimeout(() => t.classList.remove('show'), 3800);
  }
</script>

</body>
</html>
