<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Question Bank | CampusHire</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&display=swap" rel="stylesheet">

<style>
*{ margin:0; padding:0; box-sizing:border-box; font-family:'Sora',sans-serif; }
body{ background:#f1f5f9; }

/* ── NAVBAR ── */
.navbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:0 40px;
  height:64px;
  background:#fff;
  border-bottom:1px solid #e2e8f0;
  position:sticky;
  top:0;
  z-index:100;
  box-shadow:0 1px 8px rgba(0,0,0,0.06);
}
.logo{ font-size:20px; font-weight:700; color:#0f172a; }
.logo span{ color:#2563eb; }
.nav-links{ display:flex; align-items:center; gap:6px; }
.nav-links a{
  text-decoration:none;
  color:#64748b;
  font-size:14px;
  font-weight:600;
  padding:7px 14px;
  border-radius:8px;
  transition:all 0.2s;
}
.nav-links a:hover{ background:#f1f5f9; color:#0f172a; }
.nav-links a.dashboard-link{ color:#2563eb; background:#eff6ff; }
.nav-links a.dashboard-link:hover{ background:#dbeafe; }
.nav-btn{
  background:linear-gradient(135deg,#2563eb,#4f46e5);
  color:#fff;
  padding:9px 20px;
  border-radius:9px;
  text-decoration:none;
  font-size:14px;
  font-weight:600;
}

/* ── PAGE HERO ── */
.page-hero{
  background:linear-gradient(135deg,#0f172a,#1e2a5a,#3b3fbf);
  color:white;
  padding:44px 80px;
  position:relative;
  overflow:hidden;
}
.page-hero::before{
  content:'';
  position:absolute;
  width:500px; height:500px;
  background:rgba(99,102,241,0.12);
  border-radius:50%;
  top:-200px; right:-100px;
}
.page-hero h1{ font-size:34px; font-weight:700; margin-bottom:8px; position:relative; z-index:1; }
.page-hero h1 span{ color:#60a5fa; }
.page-hero p{ color:#c7d2fe; font-size:15px; position:relative; z-index:1; }

/* HERO STATS */
.hero-stats{
  display:flex;
  gap:20px;
  margin-top:24px;
  position:relative;
  z-index:1;
}
.hero-stat{
  background:rgba(255,255,255,0.1);
  border:1px solid rgba(255,255,255,0.15);
  padding:12px 20px;
  border-radius:12px;
  text-align:center;
}
.hero-stat .num{ font-size:22px; font-weight:700; }
.hero-stat .lbl{ font-size:11px; color:#c7d2fe; margin-top:2px; }

/* ── CONTROLS ── */
.controls{
  padding:24px 80px 0;
}

/* SEARCH */
.search-wrap{
  position:relative;
  margin-bottom:16px;
}
.search-icon{
  position:absolute;
  left:16px; top:50%;
  transform:translateY(-50%);
  font-size:16px; color:#94a3b8;
}
.search-input{
  width:100%;
  padding:13px 18px 13px 44px;
  border-radius:12px;
  border:1.5px solid #e2e8f0;
  font-size:14px;
  font-family:'Sora',sans-serif;
  outline:none;
  background:#fff;
  transition:border 0.2s;
}
.search-input:focus{
  border-color:#2563eb;
  box-shadow:0 0 0 3px rgba(37,99,235,0.1);
}

/* FILTERS */
.filters{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  margin-bottom:16px;
}
.filter-btn{
  padding:8px 18px;
  border-radius:50px;
  border:1.5px solid #e2e8f0;
  cursor:pointer;
  background:#fff;
  color:#64748b;
  font-size:13px;
  font-weight:600;
  font-family:'Sora',sans-serif;
  transition:all 0.2s;
}
.filter-btn:hover{ border-color:#2563eb; color:#2563eb; }
.filter-btn.active{
  background:#2563eb;
  color:#fff;
  border-color:#2563eb;
  box-shadow:0 2px 8px rgba(37,99,235,0.3);
}

/* RESULTS BAR */
.results-bar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:20px;
}
.results-bar .count{ font-size:13px; color:#64748b; font-weight:600; }
.results-bar .solved-count{
  font-size:13px;
  font-weight:700;
  color:#16a34a;
  background:#dcfce7;
  padding:4px 14px;
  border-radius:50px;
}

/* ── MAIN ── */
.main{ padding:0 80px 60px; }

/* ── QUESTION CARD ── */
.q-card{
  background:#fff;
  border-radius:16px;
  margin-bottom:14px;
  border:1.5px solid #e2e8f0;
  overflow:hidden;
  transition:all 0.2s;
  position:relative;
}
.q-card::before{
  content:'';
  position:absolute;
  left:0; top:0; bottom:0;
  width:4px;
  background:linear-gradient(180deg,#3b82f6,#4f46e5);
  transition:opacity 0.2s;
}
.q-card:hover{
  border-color:#bfdbfe;
  box-shadow:0 8px 20px rgba(0,0,0,0.07);
  transform:translateY(-2px);
}

/* SOLVED STATE */
.q-card.solved{
  background:#f0fdf4;
  border-color:#86efac;
  opacity:0.82;
}
.q-card.solved::before{
  background:linear-gradient(180deg,#22c55e,#16a34a);
}
.q-card.solved .q-title{
  text-decoration:line-through;
  color:#94a3b8;
}

.q-body{
  padding:18px 20px;
  display:flex;
  align-items:flex-start;
  gap:14px;
}

/* TICK */
.tick-btn{
  width:28px; height:28px;
  border-radius:50%;
  border:2px solid #d1d5db;
  background:white;
  cursor:pointer;
  font-size:14px;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  margin-top:3px;
  transition:all 0.2s;
  color:#94a3b8;
  font-weight:700;
}
.tick-btn:hover{ border-color:#22c55e; color:#22c55e; transform:scale(1.1); }
.tick-btn.ticked{ background:#22c55e; border-color:#22c55e; color:white; }

/* Q NUMBER */
.q-num{
  width:30px; height:30px;
  background:#eff6ff;
  color:#2563eb;
  border-radius:8px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:12px;
  font-weight:700;
  flex-shrink:0;
}

/* Q CONTENT */
.q-content{ flex:1; }
.q-title{
  font-size:15px;
  font-weight:600;
  color:#0f172a;
  margin-bottom:8px;
  line-height:1.4;
  cursor:pointer;
}
.q-title:hover{ color:#2563eb; }

.tags{ display:flex; gap:6px; flex-wrap:wrap; align-items:center; }
.tag{
  padding:3px 10px;
  border-radius:50px;
  font-size:11px;
  font-weight:600;
}
.tag-easy{ background:#dcfce7; color:#16a34a; }
.tag-medium{ background:#fef3c7; color:#d97706; }
.tag-hard{ background:#fee2e2; color:#dc2626; }
.tag-gray{ background:#f1f5f9; color:#64748b; }
.tag-freq{ background:#eff6ff; color:#2563eb; }

/* Q RIGHT */
.q-right{
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  gap:8px;
  flex-shrink:0;
}
.freq-badge{
  font-size:13px;
  font-weight:700;
  color:#2563eb;
}
.chevron{
  color:#94a3b8;
  font-size:16px;
  cursor:pointer;
  transition:transform 0.2s;
}
.chevron.open{ transform:rotate(180deg); }

/* ANSWER */
.answer{
  display:none;
  padding:16px 20px 18px 72px;
  background:#f8fafc;
  border-top:1px solid #e2e8f0;
  font-size:14px;
  color:#334155;
  line-height:1.7;
}
.answer b{ color:#0f172a; display:block; margin-bottom:6px; font-size:13px; }

/* EMPTY */
.empty{
  text-align:center;
  padding:60px;
  color:#94a3b8;
  display:none;
}
.empty .emoji{ font-size:48px; margin-bottom:14px; }

/* TOAST */
.toast{
  position:fixed;
  bottom:30px; right:30px;
  background:#0f172a;
  color:#fff;
  padding:12px 20px;
  border-radius:12px;
  font-size:13px;
  font-weight:600;
  opacity:0;
  transform:translateY(10px);
  transition:all 0.3s;
  z-index:9999;
  pointer-events:none;
}
.toast.show{ opacity:1; transform:translateY(0); }
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">🎓 Campus<span>Hire</span></div>
  <div class="nav-links">
    <a href="/main">Home</a>
    <a href="/prepare">Companies</a>
    <a href="/question-bank">Question Bank</a>
    <a href="/analytics">Analytics</a>
    <a href="/dashboard" class="dashboard-link">📊 My Dashboard</a>
  </div>
  <a href="/prepare" class="nav-btn">Start Preparing →</a>
</div>

<!-- HERO -->
<div class="page-hero">
  <h1>📚 <span>Question Bank</span></h1>
  <p>Top frequently asked interview questions — sorted by importance</p>
  <div class="hero-stats">
    <div class="hero-stat">
      <div class="num"><%= questions.length %></div>
      <div class="lbl">Total Questions</div>
    </div>
    <div class="hero-stat">
      <div class="num" id="solvedHeroCount">0</div>
      <div class="lbl">Solved by You</div>
    </div>
    <div class="hero-stat">
      <div class="num">⭐ Top Picks</div>
      <div class="lbl">Sorted by Frequency</div>
    </div>
  </div>
</div>

<!-- CONTROLS -->
<div class="controls">

  <!-- SEARCH -->
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input type="text" class="search-input" placeholder="Search questions..." onkeyup="searchQ(this.value)">
  </div>

  <!-- FILTERS -->
  <div class="filters">
    <button class="filter-btn active" onclick="filter('all', this)">🌐 All</button>
    <button class="filter-btn" onclick="filter('quant', this)">🧮 Aptitude</button>
    <button class="filter-btn" onclick="filter('dsa', this)">💻 DSA</button>
    <button class="filter-btn" onclick="filter('technical', this)">⚙️ Technical</button>
    <button class="filter-btn" onclick="filter('HR', this)">🤝 HR</button>
    <button class="filter-btn" onclick="filter('solved', this)">✅ Solved</button>
    <button class="filter-btn" onclick="filter('unsolved', this)">⭕ Unsolved</button>
  </div>

  <!-- RESULTS BAR -->
  <div class="results-bar">
    <span class="count" id="qCount"><%= questions.length %> questions</span>
    <span class="solved-count">✅ <span id="solvedCount">0</span> solved</span>
  </div>

</div>

<!-- QUESTIONS -->
<div class="main">

  <% questions.forEach(function(q, i) { %>
    <div class="q-card" data-type="<%= q.category %>" id="card-<%= q._id %>">

      <div class="q-body">

        <!-- TICK -->
        <button
          class="tick-btn"
          id="tick-<%= q._id %>"
          onclick="toggleSolved('<%= q._id %>', this)"
          title="Mark as solved">
          ✓
        </button>

        <!-- NUMBER -->
        <div class="q-num"><%= i+1 %></div>

        <!-- CONTENT -->
        <div class="q-content" onclick="toggleAnswer('<%= q._id %>')" style="cursor:pointer;">
          <div class="q-title" id="title-<%= q._id %>"><%= q.questionText %></div>
          <div class="tags">
            <span class="tag <%= q.difficulty === 'Hard' ? 'tag-hard' : q.difficulty === 'Medium' ? 'tag-medium' : 'tag-easy' %>">
              <%= q.difficulty %>
            </span>
            <span class="tag tag-gray"><%= q.category %></span>
            <span class="tag tag-freq">⭐ Top Pick</span>
          </div>
        </div>

        <!-- RIGHT -->
        <div class="q-right">
          <span class="freq-badge">🔥 <%= q.frequency %>%</span>
          <span class="chevron" id="chevron-<%= q._id %>" onclick="toggleAnswer('<%= q._id %>')">⌄</span>
        </div>

      </div>

      <!-- ANSWER -->
      <div class="answer" id="answer-<%= q._id %>">
        <b>💡 APPROACH / ANSWER:</b>
        <p><%= q.approach %></p>
      </div>

    </div>
  <% }); %>

  <div class="empty" id="emptyState">
    <div class="emoji">🔎</div>
    <p>No questions found.</p>
  </div>

</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ── TOGGLE ANSWER ──
function toggleAnswer(qId) {
  const answer  = document.getElementById('answer-'  + qId);
  const chevron = document.getElementById('chevron-' + qId);
  const isOpen  = answer.style.display === 'block';
  answer.style.display = isOpen ? 'none' : 'block';
  chevron.classList.toggle('open', !isOpen);
}

// ── FILTER ──
function filter(type, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  const cards = document.querySelectorAll('.q-card');
  let visible = 0;

  cards.forEach(card => {
    let show = false;
    if      (type === 'all')      show = true;
    else if (type === 'solved')   show = card.classList.contains('solved');
    else if (type === 'unsolved') show = !card.classList.contains('solved');
    else                          show = card.dataset.type === type;

    card.style.display = show ? 'block' : 'none';
    if (show) visible++;
  });

  updateCount(visible);
}

// ── SEARCH ──
function searchQ(val) {
  const cards = document.querySelectorAll('.q-card');
  let visible = 0;

  cards.forEach(card => {
    const match = card.innerText.toLowerCase().includes(val.toLowerCase());
    card.style.display = match ? 'block' : 'none';
    if (match) visible++;
  });

  updateCount(visible);
}

// ── COUNT ──
function updateCount(n) {
  const total = n !== undefined ? n : document.querySelectorAll('.q-card:not([style*="display: none"])').length;
  document.getElementById('qCount').textContent = total + ' questions';
  document.getElementById('emptyState').style.display = total === 0 ? 'block' : 'none';
}

// ── SOLVED COUNT ──
function updateSolvedCount() {
  const solved = document.querySelectorAll('.q-card.solved').length;
  document.getElementById('solvedCount').textContent     = solved;
  document.getElementById('solvedHeroCount').textContent = solved;
}

// ── TOGGLE SOLVED ──
async function toggleSolved(questionId, btn) {
  try {
    const response = await fetch('/toggle-solved', {
      method:      'POST',
      credentials: 'include',
      headers:     { 'Content-Type': 'application/json' },
      body:        JSON.stringify({ questionId })
    });

    const data = await response.json();

    if (data.success) {
      const card  = document.getElementById('card-'  + questionId);
      const title = document.getElementById('title-' + questionId);

      if (data.solved) {
        btn.classList.add('ticked');
        card.classList.add('solved');
        showToast('✅ Marked as solved! Dashboard updated.');
      } else {
        btn.classList.remove('ticked');
        card.classList.remove('solved');
        showToast('↩️ Marked as unsolved.');
      }

      updateSolvedCount();

    } else {
      showToast('⚠️ Please login to track your progress.');
    }

  } catch(err) {
    console.log(err);
    showToast('Something went wrong.');
  }
}

// ── TOAST ──
function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2500);
}

// ── INIT ──
window.onload = function() {
  updateCount();
  updateSolvedCount();
};
</script>

</body>
</html>