<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Login | Campus Hire</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*{ margin:0; padding:0; box-sizing:border-box; font-family:'Sora',sans-serif; }

body{
  height:100vh;
  display:flex;
  background:linear-gradient(135deg,#0f172a,#1e2a5a,#3b3fbf);
}

.left{
  width:50%;
  color:white;
  display:flex;
  flex-direction:column;
  justify-content:center;
  padding:60px;
}

.left .badge{
  display:inline-block;
  background:rgba(255,255,255,0.1);
  border:1px solid rgba(255,255,255,0.2);
  padding:6px 14px;
  border-radius:50px;
  font-size:13px;
  margin-bottom:20px;
  color:#93c5fd;
  width:fit-content;
}

.left h1{ font-size:42px; line-height:1.2; }
.left span{ color:#60a5fa; }
.left p{ margin-top:16px; color:#a5b4fc; max-width:400px; line-height:1.7; font-size:15px; }

.stats-row{ display:flex; gap:24px; margin-top:40px; }
.stat{ text-align:center; }
.stat .num{ font-size:28px; font-weight:700; color:#fff; }
.stat .lbl{ font-size:12px; color:#93c5fd; margin-top:2px; }

.right{
  width:50%;
  background:#fff;
  display:flex;
  justify-content:center;
  align-items:center;
}

.login-box{ width:360px; }

.login-box h2{ font-size:26px; color:#0f172a; margin-bottom:6px; }
.login-box .sub{ color:#64748b; margin-bottom:20px; font-size:14px; }

/* ── ROLE TOGGLE ── */
.role-toggle{
  display:flex;
  background:#f1f5f9;
  border-radius:10px;
  padding:4px;
  margin-bottom:22px;
  gap:4px;
}
.role-toggle button{
  flex:1;
  padding:9px;
  border:none;
  border-radius:8px;
  background:transparent;
  color:#64748b;
  font-size:14px;
  font-weight:600;
  cursor:pointer;
  transition:all 0.2s;
  font-family:'Sora',sans-serif;
}
.role-toggle button.active{
  background:#2563eb;
  color:#fff;
  box-shadow:0 2px 8px rgba(37,99,235,0.3);
}

/* ── ERROR BANNER ── */
.error-banner{
  display:flex;
  align-items:center;
  gap:10px;
  background:#fef2f2;
  border:1.5px solid #fecaca;
  color:#b91c1c;
  padding:11px 14px;
  border-radius:10px;
  font-size:13px;
  font-weight:600;
  margin-bottom:18px;
  animation: slideDown 0.3s ease;
}
.error-banner.hidden{ display:none; }
@keyframes slideDown{
  from{ opacity:0; transform:translateY(-8px); }
  to{ opacity:1; transform:translateY(0); }
}
.error-banner .error-icon{ font-size:16px; flex-shrink:0; }
.error-close{
  margin-left:auto; background:none; border:none;
  color:#b91c1c; cursor:pointer; font-size:16px; line-height:1;
  padding:0 2px;
}

.input-group{ margin-bottom:15px; }
.input-group label{
  display:block; font-size:13px; font-weight:600;
  color:#334155; margin-bottom:6px;
}
.input-group input{
  width:100%; padding:12px 14px;
  border-radius:8px; border:1.5px solid #e2e8f0;
  outline:none; font-size:14px; font-family:'Sora',sans-serif;
  color:#0f172a; transition:border 0.2s;
}
.input-group input:focus{
  border-color:#2563eb;
  box-shadow:0 0 0 3px rgba(37,99,235,0.1);
}
.input-group input.error-input{ border-color:#f87171; }

.extra{
  display:flex; justify-content:space-between;
  margin-top:10px; font-size:13px; color:#64748b;
}
.extra label{ display:flex; align-items:center; gap:6px; cursor:pointer; }
.extra a{ text-decoration:none; color:#2563eb; font-weight:600; }

.login-btn{
  width:100%; padding:13px;
  background:linear-gradient(135deg,#2563eb,#4f46e5);
  color:white; border:none; border-radius:10px;
  cursor:pointer; font-size:15px; font-weight:600;
  font-family:'Sora',sans-serif; margin-top:18px; transition:opacity 0.2s;
}
.login-btn:hover{ opacity:0.9; }

.divider{ text-align:center; margin:20px 0; color:#cbd5e1; font-size:13px; position:relative; }
.divider::before, .divider::after{
  content:''; position:absolute; top:50%;
  width:42%; height:1px; background:#e2e8f0;
}
.divider::before{ left:0; }
.divider::after{ right:0; }

/* ── SOCIAL BUTTONS ── */
.social{ display:flex; gap:10px; }

.social-btn{
  flex:1;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  padding:11px 14px;
  border-radius:10px;
  border:1.5px solid #e2e8f0;
  background:#fff;
  cursor:pointer;
  font-size:14px;
  font-family:'Sora',sans-serif;
  color:#334155;
  font-weight:600;
  text-decoration:none;
  transition:background 0.2s, border-color 0.2s, box-shadow 0.2s;
  line-height:1;
}
.social-btn:hover{
  background:#f8fafc;
  border-color:#cbd5e1;
  box-shadow:0 2px 6px rgba(0,0,0,0.06);
}

/* Google icon SVG */
.social-btn .google-icon{
  width:18px; height:18px; flex-shrink:0;
}

/* GitHub icon SVG */
.social-btn .github-icon{
  width:18px; height:18px; flex-shrink:0; fill:#24292e;
}

.signup{
  text-align:center; margin-top:20px;
  font-size:14px; color:#64748b;
}
.signup a{ color:#2563eb; text-decoration:none; font-weight:600; }
</style>
</head>

<body>

<!-- LEFT -->
<div class="left">
  <div class="badge">✨ #1 Campus Placement Platform</div>
  <h1>Welcome to <span>CampusHire</span></h1>
  <p>Prepare smarter with real interview questions, company insights, and probability-based placement strategies tailored for you.</p>

  <div class="stats-row">
    <div class="stat">
      <div class="num">10K+</div>
      <div class="lbl">Students</div>
    </div>
    <div class="stat">
      <div class="num">50+</div>
      <div class="lbl">Companies</div>
    </div>
    <div class="stat">
      <div class="num">5K+</div>
      <div class="lbl">Questions</div>
    </div>
  </div>
</div>

<!-- RIGHT -->
<div class="right">
  <div class="login-box">
    <h2>Welcome back 👋</h2>
    <p class="sub">Sign in to your placement dashboard</p>

    <!-- ── ROLE TOGGLE ── -->
    <div class="role-toggle">
      <button type="button" id="btnStudent" class="active" onclick="setRole('student')">🎓 Student</button>
      <button type="button" id="btnAlumni"  onclick="setRole('alumni')">🏆 Alumni</button>
    </div>

    <!-- ── ERROR BANNER ── -->
    <div class="error-banner <%= typeof error !== 'undefined' && error ? '' : 'hidden' %>" id="errorBanner">
      <span class="error-icon">⚠️</span>
      <span id="errorText"><%= typeof error !== 'undefined' && error ? error : '' %></span>
      <button class="error-close" onclick="document.getElementById('errorBanner').classList.add('hidden')">✕</button>
    </div>

    <form action="/" method="POST" id="loginForm">
      <input type="hidden" name="role" id="roleInput" value="student">

      <div class="input-group">
        <label>Email Address</label>
        <input type="email" name="email" id="emailInput"
          placeholder="you@college.edu"
          value="<%= typeof formEmail !== 'undefined' ? formEmail : '' %>"
          required>
      </div>

      <div class="input-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Enter your password" required>
      </div>

      <div class="extra">
        <label><input type="checkbox"> Remember me</label>
        <a href="#">Forgot password?</a>
      </div>

      <button type="submit" class="login-btn">Sign In →</button>
    </form>

    <div class="divider">or continue with</div>

    <!-- ── SOCIAL BUTTONS ── -->
    <div class="social">

      <!-- Google (button, no real OAuth yet) -->
      <button type="button" class="social-btn">
        <!-- Official Google "G" SVG -->
        <svg class="google-icon" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path fill="#EA4335" d="M24 9.5c3.14 0 5.95 1.08 8.17 2.85l6.1-6.1C34.46 3.05 29.48 1 24 1 14.82 1 7.07 6.48 3.69 14.19l7.1 5.52C12.6 13.35 17.85 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.52 24.5c0-1.64-.15-3.22-.42-4.74H24v8.98h12.68c-.55 2.94-2.2 5.43-4.68 7.1l7.18 5.58C43.35 37.48 46.52 31.44 46.52 24.5z"/>
          <path fill="#FBBC05" d="M10.79 28.29A14.55 14.55 0 0 1 9.5 24c0-1.49.26-2.93.72-4.29l-7.1-5.52A23.93 23.93 0 0 0 0 24c0 3.87.92 7.53 2.55 10.78l8.24-6.49z"/>
          <path fill="#34A853" d="M24 47c5.48 0 10.08-1.82 13.44-4.94l-7.18-5.58c-1.82 1.22-4.15 1.94-6.26 1.94-6.15 0-11.4-3.85-13.21-9.13l-8.24 6.49C7.07 41.52 14.82 47 24 47z"/>
        </svg>
        Google
      </button>

      <!-- GitHub (anchor → real OAuth route) -->
      <a href="/auth/github" class="social-btn">
        <!-- Official GitHub mark SVG -->
        <svg class="github-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303
            3.438 9.8 8.205 11.385.6.113.82-.258.82-.577
            0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61
            -4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7
            c-1.087-.744.084-.729.084-.729 1.205.084 1.838
            1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495
            .998.108-.776.417-1.305.76-1.605-2.665-.3
            -5.466-1.332-5.466-5.93 0-1.31.465-2.38
            1.235-3.22-.135-.303-.54-1.523.105-3.176
            0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399
            3-.405 1.02.006 2.04.138 3 .405 2.28-1.552
            3.285-1.23 3.285-1.23.645 1.653.24 2.873
            .12 3.176.765.84 1.23 1.91 1.23 3.22
            0 4.61-2.805 5.625-5.475 5.92.42.36.81
            1.096.81 2.22 0 1.606-.015 2.896-.015
            3.286 0 .315.21.69.825.57C20.565 22.092
            24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
        GitHub
      </a>

    </div>

    <div class="signup">
      Don't have an account? <a href="/register">Sign up free</a>
    </div>
  </div>
</div>

<script>
  function setRole(role) {
    document.getElementById('roleInput').value = role;
    document.getElementById('btnStudent').classList.toggle('active', role === 'student');
    document.getElementById('btnAlumni').classList.toggle('active',  role === 'alumni');
  }
</script>

</body>
</html>
