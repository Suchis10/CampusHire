<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Analytics</title>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      font-family: 'Inter', sans-serif;
      box-sizing: border-box;
    }

    body {
      background: #f5f7fb;
    }

    /* ===== NAVBAR ===== */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 40px;
      background: white;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .logo {
      font-size: 22px;
      font-weight: 600;
      color: #2563eb;
    }

    .nav-links a {
      margin: 0 15px;
      text-decoration: none;
      color: #333;
      font-weight: 500;
    }

    .nav-links a.active {
      color: #2563eb;
    }

    .btn {
      background: #2563eb;
      color: white;
      padding: 10px 18px;
      border-radius: 8px;
      text-decoration: none;
    }

    /* ===== CONTAINER ===== */
    .container {
      padding: 30px 60px;
    }

    h1 {
      font-size: 32px;
      margin-bottom: 10px;
    }

    .subtitle {
      color: #6b7280;
      margin-bottom: 30px;
    }

    /* ===== CARDS ===== */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 30px;
    }

    .card {
      background: white;
      padding: 25px;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .card h2 {
      margin-top: 10px;
      font-size: 26px;
    }

    .card p {
      color: gray;
    }

    /* ===== CHART SECTION ===== */
    .charts {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 25px;
      margin-bottom: 30px;
    }

    .chart-card {
      background: white;
      padding: 20px;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    canvas {
      margin-top: 20px;
    }

    /* ===== LOWER SECTION ===== */
    .bottom {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 25px;
    }

    .bar-container {
      padding: 20px;
    }

    .progress {
      margin: 15px 0;
    }

    .progress label {
      display: flex;
      justify-content: space-between;
    }

    .progress-bar {
      height: 8px;
      background: #e5e7eb;
      border-radius: 10px;
      margin-top: 5px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: #eb259f;
    }

    /* ===== INSIGHT BOX ===== */
    .insight {
      margin-top: 30px;
      background: linear-gradient(135deg, #4f46e5, #2563eb);
      color: white;
      padding: 30px;
      border-radius: 20px;
    }

    .insight-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 20px;
    }

    .insight-card {
      background: rgba(255,255,255,0.1);
      padding: 20px;
      border-radius: 15px;
    }
  </style>
</head>

<body>

<!-- ===== NAVBAR ===== -->
<div class="navbar">
  <div class="logo">CampusHire</div>

  <div class="nav-links">
    <a href="/">Home</a>
    <a href="/companies">Companies</a>
    <a href="/question-bank">Question Bank</a>
    <a href="/analytics" class="active">Analytics</a>
  </div>

  <a href="/companies" class="btn">Start Preparing</a>
</div>

<div class="container">

  <h1>Placement Analytics</h1>
  <p class="subtitle">Data-driven insights into campus recruitment trends</p>

  <!-- ===== STATS ===== -->
  <div class="stats">
    <div class="card">
      <p>Companies Visited</p>
      <h2>50+</h2>
    </div>

    <div class="card">
      <p>Students Placed</p>
      <h2>9,250</h2>
    </div>

    <div class="card">
      <p>Avg Package</p>
      <h2>12.4 LPA</h2>
    </div>

    <div class="card">
      <p>Highest Package</p>
      <h2>81.25 LPA</h2>
    </div>
  </div>

  <!-- ===== CHARTS ===== -->
  <div class="charts">

    <div class="chart-card">
      <h3>Company Hiring Trend</h3>
      <canvas id="lineChart"></canvas>
    </div>

    <div class="chart-card">
      <h3>Question Distribution</h3>
      <canvas id="pieChart"></canvas>
    </div>

  </div>

  <!-- ===== BOTTOM ===== -->
  <div class="bottom">

    <div class="chart-card">
      <h3>Skill Demand</h3>
      <canvas id="barChart"></canvas>
    </div>

    <div class="chart-card bar-container">
      <h3>Hiring Rate</h3>

      <div class="progress">
        <label>Google <span>12%</span></label>
        <div class="progress-bar"><div class="progress-fill" style="width:12%"></div></div>
      </div>

      <div class="progress">
        <label>Amazon <span>18%</span></label>
        <div class="progress-bar"><div class="progress-fill" style="width:18%"></div></div>
      </div>

      <div class="progress">
        <label>Infosys <span>45%</span></label>
        <div class="progress-bar"><div class="progress-fill" style="width:45%"></div></div>
      </div>

      <div class="progress">
        <label>TCS <span>50%</span></label>
        <div class="progress-bar"><div class="progress-fill" style="width:50%"></div></div>
      </div>
      
      <div class="progress">
        <label>Microsoft <span>12%</span></label>
        <div class="progress-bar"><div class="progress-fill" style="width:12%"></div></div>
      </div>

      <div class="progress">
        <label>Goldman Sachs <span>18%</span></label>
        <div class="progress-bar"><div class="progress-fill" style="width:18%"></div></div>
      </div>

      <div class="progress">
        <label>JP Morgan <span>25%</span></label>
        <div class="progress-bar"><div class="progress-fill" style="width:45%"></div></div>
      </div>

      <div class="progress">
        <label>Deloitte <span>50%</span></label>
        <div class="progress-bar"><div class="progress-fill" style="width:50%"></div></div>
      </div>
    </div>

  </div>

  <!-- ===== INSIGHT ===== -->
  <div class="insight">
    <h2>Data-Driven Preparation Insights</h2>

    <div class="insight-grid">
      <div class="insight-card">
        <h3>Focus on DSA</h3>
        <p>Most companies ask DSA questions first</p>
      </div>

      <div class="insight-card">
        <h3>System Design</h3>
        <p>Important for product companies</p>
      </div>

      <div class="insight-card">
        <h3>HR Prep</h3>
        <p>Every company includes HR rounds</p>
      </div>
    </div>
  </div>

</div>

<!-- ===== CHART SCRIPT ===== -->
<script>
  // LINE CHART
  new Chart(document.getElementById("lineChart"), {
    type: 'line',
    data: {
      labels: ["Jan","Feb","Mar","Apr","May","Jun"],
      datasets: [
        { label: "Google", data: [40,50,45,60,70,80], borderColor: "#3b82f6", fill:false },
        { label: "Amazon", data: [50,60,70,75,68,85], borderColor: "#f59e0b", fill:false },
        { label: "TCS", data: [120,135,128,145,150,160], borderColor: "#ef4444", fill:false },
        { label: "Infosys", data: [90,110,105,120,125,135], borderColor: "#10b981", fill:false }
      ]
    }
  });

  // PIE CHART
  new Chart(document.getElementById("pieChart"), {
    type: 'doughnut',
    data: {
      labels: ["Coding","Technical","Aptitude","HR"],
      datasets: [{
        data: [35,28,22,15],
        backgroundColor: ["#3b82f6","#8b5cf6","#f59e0b","#10b981"]
      }]
    }
  });

  // BAR CHART
  new Chart(document.getElementById("barChart"), {
    type: 'bar',
    data: {
      labels: ["DSA","System Design","DBMS","OS","OOPS"],
      datasets: [{
        data: [95,85,75,70,88,72],
        backgroundColor: ["#3b82f6", "#8b5cf6", "#f59e0b", "#10b981", "#ef4444"]
      }]
    }
  });
</script>

</body>
</html>